  const inp = { ...sel, fontFamily: "monospace", width: 72 };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
      {rules.length === 0 && (
        <div style={{ padding: "20px", textAlign: "center", color: "#334155", fontSize: 12, borderRadius: 8, border: "1px dashed #1a2035" }}>
          No rules yet. Add one to define your strategy.
        </div>
      )}

      {rules.map((rule, idx) => {
        const condMeta = STRATEGY_CONDITIONS.find(c => c.value === rule.condition);
        return (
          <div key={rule.id} style={{
            display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap",
            padding: "10px 12px", borderRadius: 9,
            background: "#111827", border: "1px solid #1a2035",
          }}>
            {/* Rule number */}
            <span style={{ fontSize: 9, fontWeight: 700, color: "#334155", minWidth: 14 }}>#{idx + 1}</span>

            {/* Action */}
            <select value={rule.action} onChange={e => updateRule(rule.id, "action", e.target.value)}
              style={{ ...sel,
                background: rule.action === "buy" ? "rgba(16,185,129,0.1)" : "rgba(239,68,68,0.1)",
                borderColor: rule.action === "buy" ? "rgba(16,185,129,0.3)" : "rgba(239,68,68,0.3)",
                color: rule.action === "buy" ? "#34d399" : "#f87171",
                fontWeight: 700,
              }}>
              <option value="buy">BUY</option>
              <option value="sell">SELL</option>
            </select>

            <span style={{ fontSize: 10, color: "#334155" }}>when</span>

            {/* Condition */}
            <select value={rule.condition} onChange={e => updateRule(rule.id, "condition", e.target.value)}
              style={{ ...sel, flex: 1, minWidth: 180 }}>
              {STRATEGY_CONDITIONS.map(c => (
                <option key={c.value} value={c.value}>{c.label}</option>
              ))}
            </select>

            {/* Value */}
            <input
              type="number"
              value={rule.value}
              onChange={e => updateRule(rule.id, "value", e.target.value)}
              placeholder={condMeta?.hint ?? "value"}
              title={condMeta?.hint}
              style={inp}
            />

            {/* Remove */}
            <button onClick={() => removeRule(rule.id)} style={{ background: "none", border: "none", color: "#334155", cursor: "pointer", display: "flex", padding: 4, borderRadius: 4 }}>
              <X size={13}/>
            </button>
          </div>
        );
      })}

      <button onClick={addRule} style={{
        display: "flex", alignItems: "center", gap: 6,
        padding: "8px 14px", borderRadius: 8,
        border: "1px dashed #1a2035", background: "transparent",
        color: "#475569", fontSize: 11, fontWeight: 600, cursor: "pointer",
        transition: "all 0.15s", width: "fit-content",
      }}>
        <Plus size={13}/> Add Rule
      </button>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  AI STRATEGY GENERATOR
// ─────────────────────────────────────────────────────────────

const AI_EXAMPLES = [
  "Buy when RSI is oversold and price is above the 200-day MA",
  "Golden cross strategy — buy when 50MA crosses above 200MA",
  "Momentum breakout above 20-bar high in a bull market",
  "Buy the dip — RSI dip below 35 then recovery while above 50MA",
  "MACD bullish crossover for daily trend following",
];

function AIStrategyGenerator({ onGenerated, disabled }) {
  const [prompt,   setPrompt]   = useState("");
  const [loading,  setLoading]  = useState(false);
  const [error,    setError]    = useState("");
  const [lastResult, setLastResult] = useState(null);
  const [example,  setExample]  = useState(0);

  const generate = async (text = prompt) => {
    const p = text.trim();
    if (!p) return setError("Please describe your strategy first.");
    setLoading(true);
    setError("");
    setLastResult(null);

    try {
      const res = await fetch("/api/generate-strategy", {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify({ prompt: p }),
      });

      const data = await res.json();

      if (!res.ok || data.error) {
        setError(data.error ?? "Generation failed. Try rephrasing your strategy.");
        return;
      }

      setLastResult(data);
      onGenerated(data);
    } catch {
      setError("Network error — make sure the app is running.");
    } finally {
      setLoading(false);
    }
  };

  const useExample = () => {
    const ex = AI_EXAMPLES[example % AI_EXAMPLES.length];
    setPrompt(ex);
    setExample(e => e + 1);
  };

  return (
    <div style={{
      background: "linear-gradient(135deg, rgba(99,102,241,0.06) 0%, rgba(56,189,248,0.06) 100%)",
      borderRadius: 12,
      border: "1px solid rgba(99,102,241,0.2)",
      padding: "18px 20px",
      display: "flex", flexDirection: "column", gap: 14,
    }}>
      {/* Header */}
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
          <div style={{
            width: 28, height: 28, borderRadius: 8,
            background: "linear-gradient(135deg,#4f46e5,#38bdf8)",
            display: "flex", alignItems: "center", justifyContent: "center",
          }}>
            <Sparkles size={13} style={{ color: "#fff" }}/>
          </div>
          <div>
            <div style={{ fontSize: 13, fontWeight: 700, color: "#e2e8f0" }}>AI Strategy Generator</div>
            <div style={{ fontSize: 10, color: "#475569" }}>Describe your idea in plain English</div>
          </div>
        </div>
        <button
          onClick={useExample}
          style={{
            fontSize: 10, color: "#6366f1", background: "rgba(99,102,241,0.08)",
            border: "1px solid rgba(99,102,241,0.2)", borderRadius: 6,
            padding: "4px 10px", cursor: "pointer", fontWeight: 600,
            display: "flex", alignItems: "center", gap: 4,
          }}
        >
          <Wand2 size={10}/> Try example
        </button>
      </div>

      {/* Textarea */}
      <div style={{ position: "relative" }}>
        <textarea
          value={prompt}
          onChange={e => { setPrompt(e.target.value); setError(""); }}
          onKeyDown={e => { if (e.key === "Enter" && (e.metaKey || e.ctrlKey)) generate(); }}
          placeholder="e.g. Buy when RSI crosses up from oversold and price is above the 200-day moving average, sell when MACD turns negative"
          disabled={loading || disabled}
          style={{
            width: "100%", minHeight: 80, padding: "10px 14px",
            borderRadius: 9, resize: "vertical", fontFamily: "inherit",
            background: "rgba(17,24,39,0.8)", border: `1px solid ${error ? "rgba(239,68,68,0.4)" : "rgba(99,102,241,0.25)"}`,
            fontSize: 12, color: "#e2e8f0", outline: "none",
            lineHeight: 1.6, boxSizing: "border-box",
            transition: "border-color 0.15s",
            opacity: disabled ? 0.5 : 1,
          }}
        />
        <div style={{ position: "absolute", bottom: 8, right: 10, fontSize: 9, color: "#334155" }}>
          {prompt.length}/500 · ⌘↵ to generate
        </div>
      </div>

      {/* Error */}
      {error && (
        <div style={{ display: "flex", alignItems: "center", gap: 7, padding: "8px 12px", borderRadius: 8, background: "rgba(239,68,68,0.07)", border: "1px solid rgba(239,68,68,0.2)", fontSize: 11, color: "#f87171" }}>
          <AlertCircle size={12} style={{ flexShrink: 0 }}/>{error}
        </div>
      )}

      {/* Success preview */}
      {lastResult && !loading && (
        <div style={{ padding: "10px 14px", borderRadius: 8, background: "rgba(99,102,241,0.06)", border: "1px solid rgba(99,102,241,0.2)" }}>
          <div style={{ fontSize: 10, fontWeight: 700, color: "#818cf8", textTransform: "uppercase", letterSpacing: "0.07em", marginBottom: 6, display: "flex", alignItems: "center", gap: 5 }}>
            <Sparkles size={10}/> Generated — {lastResult.rules?.length} rules applied
          </div>
          <div style={{ fontSize: 11, color: "#64748b", lineHeight: 1.5 }}>{lastResult.reasoning}</div>
          {lastResult.timeframe === "1D" && (
            <div style={{ marginTop: 6, fontSize: 10, color: "#fbbf24", display: "flex", alignItems: "center", gap: 4 }}>
              <AlertCircle size={10}/> This strategy works best on the 1D (daily) chart
            </div>
          )}
        </div>
      )}

      {/* Generate button */}
      <button
        onClick={() => generate()}
        disabled={loading || !prompt.trim() || disabled}
        style={{
          display: "flex", alignItems: "center", justifyContent: "center", gap: 8,
          padding: "11px 20px", borderRadius: 9, border: "none",
          background: loading || !prompt.trim() || disabled
            ? "#1a2035"
            : "linear-gradient(135deg,#4f46e5,#38bdf8)",
          color: loading || !prompt.trim() || disabled ? "#334155" : "#fff",
          fontSize: 12, fontWeight: 700, cursor: loading || !prompt.trim() || disabled ? "not-allowed" : "pointer",
          transition: "all 0.2s",
          boxShadow: loading || !prompt.trim() || disabled ? "none" : "0 4px 20px rgba(99,102,241,0.3)",
        }}
      >
        {loading ? (
          <>
            <span style={{ display: "inline-block", width: 12, height: 12, border: "2px solid rgba(255,255,255,0.3)", borderTopColor: "#fff", borderRadius: "50%", animation: "spin 0.7s linear infinite" }}/>
            Generating rules…
          </>
        ) : lastResult ? (
          <><RefreshCw size={13}/> Regenerate</>
        ) : (
          <><Sparkles size={13}/> Generate Rules</>
        )}
      </button>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────

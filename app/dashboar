function ProfitCalendar({ trades }) {
  const today        = new Date();
  const [year,  setYear]  = useState(today.getFullYear());
  const [month, setMonth] = useState(today.getMonth()); // 0-indexed
  const [tip,   setTip]   = useState(null); // { day, x, y }

  // Build a map: "YYYY-MM-DD" → { pnl, count, wins, losses }
  const dayMap = useMemo(() => {
    const m = {};
    trades.forEach(t => {
      const d   = new Date(t.date);
      const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
      if (!m[key]) m[key] = { pnl: 0, count: 0, wins: 0, losses: 0 };
      m[key].pnl    += t.pnl;
      m[key].count  += 1;
      if (t.pnl >= 0) m[key].wins++; else m[key].losses++;
    });
    return m;
  }, [trades]);

  // Calendar grid for the selected month
  const firstDay   = new Date(year, month, 1).getDay();  // 0=Sun
  const daysInMon  = new Date(year, month + 1, 0).getDate();
  const totalCells = Math.ceil((firstDay + daysInMon) / 7) * 7;

  const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  const DAYS   = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];

  // Month-level summary
  const monthKey = `${year}-${String(month+1).padStart(2,"0")}`;
  const monthTrades = trades.filter(t => {
    const d = new Date(t.date);
    return d.getFullYear() === year && d.getMonth() === month;
  });
  const monthPnl    = monthTrades.reduce((s, t) => s + t.pnl, 0);
  const monthWins   = monthTrades.filter(t => t.pnl >= 0).length;
  const monthLosses = monthTrades.length - monthWins;

  const prevMonth = () => { if (month === 0) { setYear(y => y-1); setMonth(11); } else setMonth(m => m-1); };
  const nextMonth = () => { if (month === 11) { setYear(y => y+1); setMonth(0);  } else setMonth(m => m+1); };
  const isToday   = d => d.getFullYear() === today.getFullYear() && d.getMonth() === today.getMonth() && d.getDate() === today.getDate();

  // Cell color by PnL intensity
  const cellColor = (pnl, count) => {
    if (!count) return "transparent";
    if (pnl > 0) {
      const intensity = Math.min(pnl / 500, 1);
      return `rgba(16,185,129,${0.12 + intensity * 0.45})`;
    }
    const intensity = Math.min(Math.abs(pnl) / 500, 1);
    return `rgba(239,68,68,${0.12 + intensity * 0.45})`;
  };

  const cells = Array.from({ length: totalCells }, (_, i) => {
    const dayNum = i - firstDay + 1;
    if (dayNum < 1 || dayNum > daysInMon) return null;
    const date    = new Date(year, month, dayNum);
    const key     = `${year}-${String(month+1).padStart(2,"0")}-${String(dayNum).padStart(2,"0")}`;
    const data    = dayMap[key] || null;
    return { dayNum, date, key, data };
  });

  return (
    <div style={{ borderRadius:12, border:"1px solid rgba(51,65,85,0.6)", background:"rgba(15,23,42,0.85)", overflow:"hidden" }}>

      {/* ── Header ── */}
      <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", padding:"12px 16px", borderBottom:"1px solid rgba(30,41,59,0.8)" }}>
        <div style={{ display:"flex", alignItems:"center", gap:12 }}>
          <button onClick={prevMonth} style={{ background:"none", border:"1px solid rgba(51,65,85,0.6)", borderRadius:6, color:"#64748b", cursor:"pointer", width:26, height:26, display:"flex", alignItems:"center", justifyContent:"center", fontSize:14, padding:0 }}>‹</button>
          <span style={{ fontSize:13, fontWeight:700, color:"#e2e8f0", minWidth:90, textAlign:"center" }}>{MONTHS[month]} {year}</span>
          <button onClick={nextMonth} style={{ background:"none", border:"1px solid rgba(51,65,85,0.6)", borderRadius:6, color:"#64748b", cursor:"pointer", width:26, height:26, display:"flex", alignItems:"center", justifyContent:"center", fontSize:14, padding:0 }}>›</button>
        </div>

        {/* Month summary pills */}
        <div style={{ display:"flex", alignItems:"center", gap:8 }}>
          <span style={{ fontSize:10, fontFamily:"monospace", color:"#64748b" }}>{monthTrades.length} trades</span>
          {monthTrades.length > 0 && <>
            <span style={{ fontSize:10, fontFamily:"monospace", color:"#34d399" }}>{monthWins}W</span>
            <span style={{ fontSize:10, fontFamily:"monospace", color:"#f87171" }}>{monthLosses}L</span>
            <span style={{ fontSize:11, fontFamily:"monospace", fontWeight:700, color: monthPnl >= 0 ? "#34d399" : "#f87171" }}>
              {monthPnl >= 0 ? "+" : ""}{monthPnl.toFixed(2)}
            </span>
          </>}
        </div>
      </div>

      {/* ── Day-of-week labels ── */}
      <div style={{ display:"grid", gridTemplateColumns:"repeat(7,1fr)", gap:2, padding:"8px 12px 4px" }}>
        {DAYS.map(d => (
          <div key={d} style={{ textAlign:"center", fontSize:9, fontWeight:700, color:"#475569", textTransform:"uppercase", letterSpacing:"0.06em", padding:"4px 0" }}>{d}</div>
        ))}
      </div>

      {/* ── Calendar grid ── */}
      <div style={{ position:"relative", display:"grid", gridTemplateColumns:"repeat(7,1fr)", gap:2, padding:"0 12px 12px" }}>
        {cells.map((cell, i) => {
          if (!cell) return <div key={`empty-${i}`}/>;
          const { dayNum, date, data } = cell;
          const bg  = data ? cellColor(data.pnl, data.count) : "transparent";
          const isTd = isToday(date);
          const pnlPos = data ? data.pnl >= 0 : null;

          return (
            <div
              key={cell.key}
              onMouseEnter={e => {
                if (!data) return;
                const rect = e.currentTarget.getBoundingClientRect();
                const parent = e.currentTarget.closest("[data-cal]").getBoundingClientRect();
                setTip({ data, dayNum, x: rect.left - parent.left + rect.width / 2, y: rect.top - parent.top });
              }}
              onMouseLeave={() => setTip(null)}
              style={{
                position:"relative",
                borderRadius:6,
                border: isTd ? "1px solid rgba(56,189,248,0.5)" : "1px solid rgba(51,65,85,0.2)",
                background: bg,
                padding:"5px 4px 4px",
                minHeight:44,
                cursor: data ? "pointer" : "default",
                transition:"background 0.15s, border-color 0.15s",
              }}
            >
              {/* Day number */}
              <div style={{ fontSize:10, fontWeight: isTd ? 700 : 500, color: isTd ? "#38bdf8" : data ? "#e2e8f0" : "#475569", lineHeight:1, marginBottom:4 }}>
                {dayNum}
              </div>

              {/* PnL amount */}
              {data && (
                <div style={{ fontSize:9, fontFamily:"monospace", fontWeight:700, color: pnlPos ? "#34d399" : "#f87171", lineHeight:1, marginBottom:3, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>
                  {pnlPos ? "+" : ""}{data.pnl.toFixed(1)}
                </div>
              )}

              {/* Trade count dots */}
              {data && (
                <div style={{ display:"flex", gap:2, flexWrap:"wrap" }}>
                  {Array.from({ length: Math.min(data.count, 6) }).map((_, di) => (
                    <div key={di} style={{
                      width:4, height:4, borderRadius:"50%",
                      background: di < data.wins ? "#10b981" : "#ef4444",
                      opacity:0.85,
                    }}/>
                  ))}
                  {data.count > 6 && <div style={{ fontSize:7, color:"#64748b", lineHeight:"4px" }}>+{data.count - 6}</div>}
                </div>
              )}
            </div>
          );
        })}

        {/* Hover tooltip */}
        {tip && (
          <div
            data-tip
            style={{
              position:"absolute",
              left: tip.x, top: tip.y - 8,
              transform:"translate(-50%,-100%)",
              background:"rgba(10,15,30,0.97)",
              border:"1px solid rgba(99,102,241,0.4)",
              borderRadius:8,
              padding:"8px 12px",
              fontSize:11,
              zIndex:50,
              pointerEvents:"none",
              whiteSpace:"nowrap",
              boxShadow:"0 8px 24px rgba(0,0,0,0.5)",
            }}
          >
            <div style={{ fontWeight:700, color:"#e2e8f0", marginBottom:4 }}>
              {MONTHS[month]} {tip.dayNum}, {year}
            </div>
            <div style={{ display:"flex", flexDirection:"column", gap:2 }}>
              <div style={{ display:"flex", justifyContent:"space-between", gap:16 }}>
                <span style={{ color:"#64748b" }}>Trades</span>
                <span style={{ color:"#e2e8f0", fontFamily:"monospace" }}>{tip.data.count}</span>
              </div>
              <div style={{ display:"flex", justifyContent:"space-between", gap:16 }}>
                <span style={{ color:"#64748b" }}>W / L</span>
                <span style={{ fontFamily:"monospace" }}>
                  <span style={{ color:"#34d399" }}>{tip.data.wins}</span>
                  <span style={{ color:"#475569" }}> / </span>
                  <span style={{ color:"#f87171" }}>{tip.data.losses}</span>
                </span>
              </div>
              <div style={{ display:"flex", justifyContent:"space-between", gap:16 }}>
                <span style={{ color:"#64748b" }}>Daily PnL</span>
                <span style={{ fontFamily:"monospace", fontWeight:700, color: tip.data.pnl >= 0 ? "#34d399" : "#f87171" }}>
                  {tip.data.pnl >= 0 ? "+" : ""}{tip.data.pnl.toFixed(2)}
                </span>
              </div>
            </div>
          </div>
        )}
      </div>

      {/* ── Legend ── */}
      <div style={{ display:"flex", alignItems:"center", gap:16, padding:"8px 16px 12px", borderTop:"1px solid rgba(30,41,59,0.5)" }}>
        <span style={{ fontSize:9, color:"#475569", textTransform:"uppercase", letterSpacing:"0.06em" }}>Legend</span>
        {[
          { color:"rgba(16,185,129,0.6)", label:"Profit day" },
          { color:"rgba(239,68,68,0.6)",  label:"Loss day"   },
          { color:"rgba(56,189,248,0.5)", label:"Today", border:true },
        ].map(({ color, label, border }) => (
          <div key={label} style={{ display:"flex", alignItems:"center", gap:5 }}>
            <div style={{ width:12, height:12, borderRadius:3, background: border ? "transparent" : color, border: border ? `1px solid ${color}` : "none" }}/>
            <span style={{ fontSize:9, color:"#64748b" }}>{label}</span>
          </div>
        ))}
        <div style={{ display:"flex", alignItems:"center", gap:5 }}>
          <div style={{ display:"flex", gap:2 }}>
            <div style={{ width:4, height:4, borderRadius:"50%", background:"#10b981" }}/>
            <div style={{ width:4, height:4, borderRadius:"50%", background:"#ef4444" }}/>
          </div>
          <span style={{ fontSize:9, color:"#64748b" }}>Win / Loss dots</span>
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════
//  JOURNAL TAB
// ═══════════════════════════════════════════════════════════════

function JournalTab({ trades, onRemove, onUpdate, onLoadDemo }) {
  const [search,   setSearch]   = useState("");
  const [typeF,    setTypeF]    = useState("all");
  const [symF,     setSymF]     = useState("all");
  const [stratF,   setStratF]   = useState("all");
  const [tagF,     setTagF]     = useState("all");
  const [sortK,    setSortK]    = useState("date");
  const [sortD,    setSortD]    = useState("desc");
  const [editing,  setEditing]  = useState(null); // trade being edited

  const stats     = useMemo(() => computeStats(trades), [trades]);
  const chartData = useMemo(() => buildCumPnl(trades),  [trades]);
  const symbols   = useMemo(() => ["all", ...Array.from(new Set(trades.map(t => t.symbol))).sort()], [trades]);
  const strategies = useMemo(() => ["all", ...Array.from(new Set(trades.map(t => t.strategy).filter(Boolean))).sort()], [trades]);
  const allTags    = useMemo(() => ["all", ...Array.from(new Set(trades.flatMap(t => t.tags ?? []))).sort()], [trades]);

  const finalPnl = chartData.length ? chartData[chartData.length - 1].cumPnl : 0;
  const lineClr  = finalPnl >= 0 ? "#10b981" : "#ef4444";
  const vals     = chartData.map(d => d.cumPnl);
  const minV     = Math.min(...vals, 0);
  const maxV     = Math.max(...vals, 0);
  const pad2     = (maxV - minV) * 0.15 || 50;

  const filtered = useMemo(() => {
    let r = [...trades];
    if (search) {
      const q = search.toLowerCase();
      r = r.filter(t =>
        t.symbol.toLowerCase().includes(q) ||
        (t.strategy ?? "").toLowerCase().includes(q) ||
        (t.notes ?? "").toLowerCase().includes(q) ||
        (t.tags ?? []).some(tag => tag.toLowerCase().includes(q))
      );
    }
    if (typeF   !== "all") r = r.filter(t => t.type === typeF);
    if (symF    !== "all") r = r.filter(t => t.symbol === symF);
    if (stratF  !== "all") r = r.filter(t => (t.strategy ?? "") === stratF);
    if (tagF    !== "all") r = r.filter(t => (t.tags ?? []).includes(tagF));
    r.sort((a, b) => {
      const va = a[sortK], vb = b[sortK];
      const c  = va < vb ? -1 : va > vb ? 1 : 0;
      return sortD === "asc" ? c : -c;
    });
    return r;
  }, [trades, search, typeF, symF, stratF, tagF, sortK, sortD]);

  const toggleSort = k => {
    if (sortK === k) setSortD(d => d === "asc" ? "desc" : "asc");
    else { setSortK(k); setSortD("desc"); }
  };

  const SIcon = ({ c }) => c !== sortK
    ? <ChevronsUpDown size={10} style={{ color: "#475569" }} />
    : sortD === "asc"
      ? <ChevronUp   size={10} style={{ color: "#38bdf8" }} />
      : <ChevronDown size={10} style={{ color: "#38bdf8" }} />;

  const streakLabel = stats.currentStreak > 0
    ? `${stats.currentStreak}W`
    : stats.currentStreak < 0 ? `${Math.abs(stats.currentStreak)}L` : "—";

  const TH = ({ c, label }) => (
    <th onClick={() => toggleSort(c)} style={{
      padding: "8px 12px", textAlign: "left", fontSize: 9, fontWeight: 700,
      color: "#64748b", textTransform: "uppercase", letterSpacing: "0.07em",
      cursor: "pointer", userSelect: "none", whiteSpace: "nowrap",
      borderBottom: "1px solid rgba(30,41,59,0.8)", background: "rgba(10,15,30,0.98)",
    }}>
      <div style={{ display: "flex", alignItems: "center", gap: 3 }}>
        {label}<SIcon c={c} />
      </div>
    </th>
  );

  const th0 = { padding:"8px 12px", textAlign:"left", fontSize:9, fontWeight:700, color:"#64748b",
    textTransform:"uppercase", letterSpacing:"0.07em", whiteSpace:"nowrap",
    borderBottom:"1px solid rgba(30,41,59,0.8)", background:"rgba(10,15,30,0.98)" };

  const td = { padding: "9px 12px", fontSize: 11, borderBottom: "1px solid rgba(30,41,59,0.5)" };

  const selStyle = { padding:"4px 8px", borderRadius:8, background:"#1e293b", border:"1px solid #334155", fontSize:10, color:"#cbd5e1", cursor:"pointer", outline:"none" };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>

      {/* Edit modal */}
      {editing && (
        <TradeEditModal
          trade={editing}
          onSave={updated => onUpdate(updated)}
          onClose={() => setEditing(null)}
        />
      )}

      {/* ── Stats grid ── */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit,minmax(130px,1fr))", gap: 10 }}>
        <StatCard label="Total Trades" value={String(stats.totalTrades)} sub={`${stats.wins}W / ${stats.losses}L`} pos={null} icon={<Activity size={14}/>}/>
        <StatCard label="Win Rate"    value={`${stats.winRate}%`}        sub={`PF ${stats.profitFactor}`}           pos={stats.winRate >= 50}       icon={<Target size={14}/>}/>
        <StatCard label="Total PnL"   value={`${stats.totalPnl >= 0 ? "+" : ""}${stats.totalPnl.toFixed(2)}`}      sub={`Avg W: +${stats.avgWin.toFixed(2)}`} pos={stats.totalPnl >= 0} icon={<TrendingUp size={14}/>}/>
        <StatCard label="Best Trade"  value={`+${stats.bestTrade.toFixed(2)}`}  pos={true}  icon={<Award size={14}/>}/>
        <StatCard label="Worst Trade" value={stats.worstTrade.toFixed(2)}       pos={false} icon={<TrendingDown size={14}/>}/>
        <StatCard label="Streak"      value={streakLabel} sub={`Avg L: -${stats.avgLoss.toFixed(2)}`}
          pos={stats.currentStreak > 0 ? true : stats.currentStreak < 0 ? false : null}
          icon={<Zap size={14}/>}/>
      </div>

      {/* ── Analytics Panel ── */}
      <AnalyticsPanel trades={trades}/>

      {/* ── Profit Calendar ── */}
      <div data-cal style={{ position:"relative" }}>
        <ProfitCalendar trades={trades}/>
      </div>

      {/* ── Cumulative PnL chart ── */}
      {chartData.length > 0 && (
        <div style={{ borderRadius: 12, border: "1px solid rgba(51,65,85,0.6)", background: "rgba(15,23,42,0.85)", padding: "16px 16px 8px" }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 14 }}>
            <span style={{ fontSize: 12, fontWeight: 500, color: "#cbd5e1" }}>Cumulative PnL</span>
            <span style={{ fontSize: 12, fontFamily: "monospace", fontWeight: 700, color: lineClr }}>
              {finalPnl >= 0 ? "+" : ""}{finalPnl.toFixed(2)}
            </span>
          </div>
          <ResponsiveContainer width="100%" height={180}>
            <AreaChart data={chartData} margin={{ top: 4, right: 4, left: -20, bottom: 0 }}>
              <defs>
                <linearGradient id="pnlGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%"   stopColor={lineClr} stopOpacity={0.25}/>
                  <stop offset="100%" stopColor={lineClr} stopOpacity={0.01}/>
                </linearGradient>
              </defs>
              <CartesianGrid strokeDasharray="3 3" stroke="#1e293b" vertical={false}/>
              <XAxis dataKey="label" tick={{ fill:"#64748b", fontSize:9 }} axisLine={false} tickLine={false} interval="preserveStartEnd"/>
              <YAxis tick={{ fill:"#64748b", fontSize:9 }} axisLine={false} tickLine={false} domain={[minV - pad2, maxV + pad2]} tickFormatter={v => v.toFixed(0)}/>
              <Tooltip content={<PnlTooltip/>}/>
              <Area type="monotone" dataKey="cumPnl" stroke={lineClr} strokeWidth={2} fill="url(#pnlGrad)" dot={false} activeDot={{ r:4, fill:lineClr, strokeWidth:0 }}/>
            </AreaChart>
          </ResponsiveContainer>
        </div>
      )}

      {/* ── Trade history table ── */}
      <div style={{ borderRadius: 12, border: "1px solid rgba(51,65,85,0.6)", background: "rgba(15,23,42,0.85)", overflow: "hidden" }}>

        {/* Toolbar row 1 — search + type + symbol */}
        <div style={{ display:"flex", flexWrap:"wrap", alignItems:"center", gap:8, padding:"10px 12px 6px", borderBottom:"1px solid rgba(30,41,59,0.5)" }}>
          <div style={{ position:"relative", flex:1, minWidth:140 }}>
            <Search size={11} style={{ position:"absolute", left:8, top:"50%", transform:"translateY(-50%)", color:"#64748b", pointerEvents:"none" }}/>
            <input
              placeholder="Search symbol, strategy, tags, notes…"
              value={search}
              onChange={e => setSearch(e.target.value)}
              style={{ width:"100%", paddingLeft:26, paddingRight:24, paddingTop:5, paddingBottom:5, borderRadius:8, background:"#1e293b", border:"1px solid #334155", fontSize:11, color:"#cbd5e1", outline:"none", boxSizing:"border-box" }}
            />
            {search && (
              <button onClick={() => setSearch("")} style={{ position:"absolute", right:6, top:"50%", transform:"translateY(-50%)", background:"none", border:"none", color:"#64748b", cursor:"pointer", display:"flex" }}>
                <X size={10}/>
              </button>
            )}
          </div>
          {/* Direction */}
          <div style={{ display:"flex", borderRadius:8, overflow:"hidden", border:"1px solid #334155" }}>
            {["all","long","short"].map(f => (
              <button key={f} onClick={() => setTypeF(f)} style={{
                padding:"4px 10px", fontSize:10, fontWeight:700, textTransform:"capitalize", cursor:"pointer", border:"none",
                background: typeF === f ? (f==="long" ? "rgba(16,185,129,0.15)" : f==="short" ? "rgba(239,68,68,0.15)" : "#334155") : "rgba(30,41,59,0.5)",
                color:      typeF === f ? (f==="long" ? "#34d399"                : f==="short" ? "#f87171"                : "#cbd5e1") : "#64748b",
                transition: "all 0.15s",
              }}>{f}</button>
            ))}
          </div>
          <select value={symF}   onChange={e => setSymF(e.target.value)}   style={selStyle}>
            {symbols.map(s => <option key={s} value={s}>{s === "all" ? "All Symbols" : s}</option>)}
          </select>
          <select value={stratF} onChange={e => setStratF(e.target.value)} style={selStyle}>
            {strategies.map(s => <option key={s} value={s}>{s === "all" ? "All Strategies" : s}</option>)}
          </select>
          <select value={tagF}   onChange={e => setTagF(e.target.value)}   style={selStyle}>
            {allTags.map(t => <option key={t} value={t}>{t === "all" ? "All Tags" : t}</option>)}
          </select>
          <button onClick={onLoadDemo} style={{ padding:"4px 10px", borderRadius:8, border:"1px solid #334155", background:"none", color:"#64748b", fontSize:10, cursor:"pointer", display:"flex", alignItems:"center", gap:4 }}>
            <RotateCcw size={10}/>Demo
          </button>
          <span style={{ marginLeft:"auto", fontSize:10, color:"#475569", fontFamily:"monospace" }}>{filtered.length} trades</span>
        </div>

        {/* Table */}
        <div style={{ overflowX:"auto", overflowY:"auto", maxHeight:380 }}>
          <table style={{ width:"100%", borderCollapse:"collapse", fontSize:11 }}>
            <thead>
              <tr>
                <TH c="date"       label="Date"       />
                <TH c="symbol"     label="Symbol"     />
                <TH c="type"       label="Type"       />
                <TH c="entryPrice" label="Entry"      />
                <TH c="exitPrice"  label="Exit"       />
                <TH c="pnl"        label="PnL"        />
                <TH c="pnlPercent" label="%"          />
                <TH c="strategy"   label="Strategy"   />
                <th style={th0}>Tags</th>
                <TH c="confidence" label="Conf"       />
                <th style={th0}>Notes</th>
                <th style={{ ...th0, width:28 }}/>
              </tr>
            </thead>
            <tbody>
              {!filtered.length ? (
                <tr><td colSpan={12} style={{ textAlign:"center", padding:"40px", color:"#475569", fontSize:12 }}>No trades match your filters.</td></tr>
              ) : filtered.map((t, i) => {
                const w = t.pnl >= 0;
                return (
                  <tr key={t.id} style={{ background: i % 2 === 0 ? "transparent" : "rgba(30,41,59,0.12)" }}>
                    {/* Date */}
                    <td style={{ ...td, color:"#94a3b8", fontFamily:"monospace", whiteSpace:"nowrap" }}>
                      {new Date(t.date).toLocaleDateString("en-US",{ month:"short", day:"numeric", year:"2-digit" })}
                    </td>
                    {/* Symbol */}
                    <td style={{ ...td, fontWeight:700, color:"#e2e8f0", letterSpacing:"0.03em" }}>{t.symbol}</td>
                    {/* Type */}
                    <td style={td}>
                      <span style={{
                        display:"inline-flex", padding:"2px 7px", borderRadius:4,
                        fontSize:9, fontWeight:700, textTransform:"uppercase", letterSpacing:"0.06em",
                        background: t.type==="long" ? "rgba(16,185,129,0.1)" : "rgba(239,68,68,0.1)",
                        color:      t.type==="long" ? "#34d399"               : "#f87171",
                        border:    `1px solid ${t.type==="long" ? "rgba(16,185,129,0.25)" : "rgba(239,68,68,0.25)"}`,
                      }}>
                        {t.type === "long" ? "▲" : "▼"} {t.type}
                      </span>
                    </td>
                    {/* Entry / Exit */}
                    <td style={{ ...td, fontFamily:"monospace", color:"#cbd5e1" }}>{t.entryPrice.toLocaleString()}</td>
                    <td style={{ ...td, fontFamily:"monospace", color:"#cbd5e1" }}>{t.exitPrice.toLocaleString()}</td>
                    {/* PnL */}
                    <td style={{ ...td, fontFamily:"monospace", fontWeight:700, color: w ? "#34d399" : "#f87171" }}>
                      {w ? "+" : ""}{t.pnl.toFixed(2)}
                    </td>
                    <td style={{ ...td, fontFamily:"monospace", color: w ? "#34d399" : "#f87171" }}>
                      {w ? "+" : ""}{t.pnlPercent.toFixed(2)}%
                    </td>
                    {/* Strategy */}
                    <td style={{ ...td, color:"#94a3b8", whiteSpace:"nowrap" }}>{t.strategy ?? "—"}</td>
                    {/* Tags */}
                    <td style={{ ...td, maxWidth:180 }}>
                      <div style={{ display:"flex", flexWrap:"wrap", gap:3 }}>
                        {(t.tags ?? []).map(tag => {
                          const clr = tagColor(tag);
                          return (
                            <span key={tag} style={{
                              padding:"1px 6px", borderRadius:20, fontSize:8, fontWeight:700,
                              background:clr.bg, border:`1px solid ${clr.border}`, color:clr.text,
                              whiteSpace:"nowrap",
                            }}>{tag}</span>
                          );
                        })}
                        {!(t.tags ?? []).length && <span style={{ color:"#334155", fontSize:10 }}>—</span>}
                      </div>
                    </td>
                    {/* Confidence stars */}
                    <td style={{ ...td, whiteSpace:"nowrap" }}>
                      {t.confidence != null ? (
                        <span style={{ fontSize:10, letterSpacing:"-1px" }}>
                          {Array.from({ length:5 }).map((_, si) => (
                            <span key={si} style={{ color: si < t.confidence ? "#fbbf24" : "#1e293b" }}>★</span>
                          ))}
                        </span>
                      ) : <span style={{ color:"#334155", fontSize:10 }}>—</span>}
                    </td>
                    {/* Notes */}
                    <td style={{ ...td, color:"#64748b", maxWidth:180, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}
                      title={t.notes}>
                      {t.notes || "—"}
                    </td>
                    {/* Actions */}
                    <td style={{ ...td, whiteSpace:"nowrap" }}>
                      <div style={{ display:"flex", gap:6 }}>
                        <button onClick={() => setEditing(t)} style={{ background:"none", border:"none", color:"#475569", cursor:"pointer", display:"flex", padding:0 }} title="Edit">
                          <span style={{ fontSize:11 }}>✎</span>
                        </button>
                        <button onClick={() => onRemove(t.id)} style={{ background:"none", border:"none", color:"#334155", cursor:"pointer", display:"flex", padding:0 }} title="Delete">
                          <Trash2 size={12}/>
                        </button>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}


// ═══════════════════════════════════════════════════════════════
//  ACTIVE TRADES TABLE
// ═══════════════════════════════════════════════════════════════

function ActiveTradesTable({ trades, onClose }) {
  if (!trades.length) {
    return (
      <div style={{ display:"flex", alignItems:"center", justifyContent:"center", height:"100%", gap:8, color:"#475569", fontSize:12 }}>
        <Activity size={14}/> No open positions
      </div>
    );
  }

  const th = {
    padding:"6px 10px", textAlign:"left", fontSize:9, fontWeight:700,
    color:"#64748b", textTransform:"uppercase", letterSpacing:"0.07em",
    borderBottom:"1px solid rgba(30,41,59,0.8)", whiteSpace:"nowrap",
    background:"rgba(10,15,30,0.98)",
  };
  const td = { padding:"8px 10px", fontSize:11, borderBottom:"1px solid rgba(30,41,59,0.5)" };

  return (
    <div style={{ overflowX:"auto", height:"100%" }}>
      <table style={{ width:"100%", borderCollapse:"collapse", fontSize:11, minWidth:600 }}>
        <thead>
          <tr>
            {["Symbol","Type","Entry","Current","SL","TP","PnL","PnL %","Age",""].map(h => (
              <th key={h} style={th}>{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {trades.map(t => {
            const w   = t.pnl >= 0;
            const cfg = SYMBOLS_CFG[t.symbol];
            const sec = Math.floor((Date.now() - t.openedAt) / 1000);
            const age = sec < 60 ? `${sec}s` : sec < 3600 ? `${Math.floor(sec/60)}m${sec%60}s` : `${Math.floor(sec/3600)}h`;
            const dp  = cfg?.dec ?? 2;

            return (
              <tr key={t.id}>
                <td style={{ ...td, fontWeight:700, color:"#e2e8f0", fontFamily:"monospace" }}>{t.symbol}</td>
                <td style={td}>
                  <span style={{
                    display:"inline-flex", padding:"2px 7px", borderRadius:4,
                    fontSize:9, fontWeight:700, textTransform:"uppercase",
                    background: t.type==="long" ? "rgba(16,185,129,0.1)" : "rgba(239,68,68,0.1)",
                    color:      t.type==="long" ? "#34d399"               : "#f87171",
                    border:    `1px solid ${t.type==="long" ? "rgba(16,185,129,0.25)" : "rgba(239,68,68,0.25)"}`,
                  }}>
                    {t.type === "long" ? "▲" : "▼"} {t.type}
                  </span>
                </td>
                <td style={{ ...td, fontFamily:"monospace", color:"#94a3b8" }}>{t.entryPrice.toFixed(dp)}</td>
                <td style={{ ...td, fontFamily:"monospace", fontWeight:700, color: w ? "#34d399" : "#f87171" }}>{t.currentPrice.toFixed(dp)}</td>
                <td style={{ ...td, fontFamily:"monospace", color:"rgba(248,113,113,0.7)" }}>{t.stopLoss   != null ? t.stopLoss.toFixed(dp)   : "—"}</td>
                <td style={{ ...td, fontFamily:"monospace", color:"rgba(52,211,153,0.7)"  }}>{t.takeProfit != null ? t.takeProfit.toFixed(dp) : "—"}</td>
                <td style={{ ...td, fontFamily:"monospace", fontWeight:700, color: w ? "#34d399" : "#f87171" }}>
                  {w ? "+" : ""}{t.pnl.toFixed(2)}
                </td>
                <td style={td}>
                  <span style={{ display:"inline-flex", padding:"2px 6px", borderRadius:4, fontSize:9, fontFamily:"monospace", background: w ? "rgba(16,185,129,0.08)" : "rgba(239,68,68,0.08)", color: w ? "#34d399" : "#f87171" }}>
                    {w ? "+" : ""}{t.pnlPercent.toFixed(3)}%
                  </span>
                </td>
                <td style={{ ...td, fontFamily:"monospace", color:"#64748b" }}>{age}</td>
                <td style={td}>
                  <button onClick={() => onClose(t.id)} style={{
                    display:"flex", alignItems:"center", gap:4,
                    padding:"3px 8px", borderRadius:6, fontSize:10, fontWeight:600,
                    border:"1px solid rgba(51,65,85,0.6)", background:"none",
                    color:"#64748b", cursor:"pointer", transition:"all 0.15s",
                  }}>
                    <X size={10}/> Close
                  </button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════
//  ORDER FORM  (right panel)
// ═══════════════════════════════════════════════════════════════

function OrderForm({ symbol, currentPrice, onOpen }) {
  const cfg = SYMBOLS_CFG[symbol] ?? SYMBOLS_CFG.BTCUSD;

  const [dir,   setDir]   = useState("long");
  const [mkt,   setMkt]   = useState(true);
  const [entry, setEntry] = useState("");
  const [sl,    setSl]    = useState("");
  const [tp,    setTp]    = useState("");
  const [size,  setSize]  = useState("1");
  const [err,   setErr]   = useState("");
  const [flash, setFlash] = useState(false);

  useEffect(() => {
    if (mkt) setEntry(currentPrice.toFixed(cfg.dec));
  }, [currentPrice, mkt, cfg.dec]);

  useEffect(() => { setSl(""); setTp(""); setErr(""); }, [symbol]);

  const suggestSL = () => {
    const e = parseFloat(entry) || currentPrice, off = e * 0.015;
    setSl((dir === "long" ? e - off : e + off).toFixed(cfg.dec));
  };
  const suggestTP = () => {
    const e = parseFloat(entry) || currentPrice, off = e * 0.03;
    setTp((dir === "long" ? e + off : e - off).toFixed(cfg.dec));
  };

  const estPnl = useMemo(() => {
    if (!tp) return null;
    const e = parseFloat(entry) || currentPrice;
    const t2 = parseFloat(tp);
    const s = parseFloat(size) || 1;
    if (!isNaN(t2) && !isNaN(e))
      return ((dir === "long" ? 1 : -1) * (t2 - e) * s).toFixed(2);
    return null;
  }, [tp, entry, currentPrice, size, dir]);

  const submit = () => {
    setErr("");
    const e  = parseFloat(entry);
    const s2 = sl ? parseFloat(sl) : null;
    const t2 = tp ? parseFloat(tp) : null;
    const sz = parseFloat(size);
    if (isNaN(e) || e <= 0)  return setErr("Invalid entry price.");
    if (isNaN(sz) || sz <= 0) return setErr("Invalid size.");
    if (s2 != null && (dir === "long" ? s2 >= e : s2 <= e))
      return setErr(`SL must be ${dir === "long" ? "below" : "above"} entry.`);
    if (t2 != null && (dir === "long" ? t2 <= e : t2 >= e))
      return setErr(`TP must be ${dir === "long" ? "above" : "below"} entry.`);
    onOpen({ symbol, type: dir, entryPrice: e, stopLoss: s2, takeProfit: t2, size: sz });
    setFlash(true);
    setTimeout(() => setFlash(false), 1000);
    setSl(""); setTp("");
  };

  // Shared input style
  const inp = {
    width: "100%", padding: "8px 11px", borderRadius: 7,
    background: "#111827", border: "1px solid #1a2035",
    fontSize: 12, color: "#e2e8f0", outline: "none",
    boxSizing: "border-box", fontFamily: "monospace",
    transition: "border-color 0.15s",
  };
  const lbl = {
    display: "block", fontSize: 9, fontWeight: 700, color: "#334155",
    textTransform: "uppercase", letterSpacing: "0.09em", marginBottom: 5,
  };

  // R/R ratio
  const rr = useMemo(() => {
    const e  = parseFloat(entry) || currentPrice;
    const s2 = parseFloat(sl);
    const t2 = parseFloat(tp);
    if (!sl || !tp || isNaN(s2) || isNaN(t2)) return null;
    const risk   = Math.abs(e - s2);
    const reward = Math.abs(e - t2);
    if (risk === 0) return null;
    return (reward / risk).toFixed(1);
  }, [entry, sl, tp, currentPrice]);

  return (
    <div style={{ display: "flex", flexDirection: "column", height: "100%", overflow: "hidden" }}>

      {/* Panel header */}
      <div style={{
        padding: "12px 16px", borderBottom: "1px solid #1a2035",
        flexShrink: 0, display: "flex", alignItems: "center", justifyContent: "space-between",
      }}>
        <span style={{ fontSize: 11, fontWeight: 700, color: "#64748b", textTransform: "uppercase", letterSpacing: "0.08em" }}>Order</span>
        <span style={{ fontSize: 11, fontFamily: "monospace", fontWeight: 700, color: "#475569" }}>{symbol}</span>
      </div>

      {/* Scrollable body */}
      <div style={{ flex: 1, overflowY: "auto", display: "flex", flexDirection: "column" }}>

        {/* Long / Short toggle */}
        <div style={{ padding: "16px 16px 0" }}>
          <div style={{ display: "flex", borderRadius: 8, overflow: "hidden", border: "1px solid #1a2035" }}>
            {["long", "short"].map(d => (
              <button key={d} onClick={() => setDir(d)} style={{
                flex: 1, padding: "11px 0", fontSize: 12, fontWeight: 700,
                textTransform: "uppercase", letterSpacing: "0.06em",
                cursor: "pointer", border: "none", transition: "all 0.15s",
                background: dir === d
                  ? (d === "long" ? "rgba(16,185,129,0.15)" : "rgba(239,68,68,0.15)")
                  : "transparent",
                color: dir === d
                  ? (d === "long" ? "#34d399" : "#f87171")
                  : "#334155",
              }}>
                {d === "long" ? "▲ Long" : "▼ Short"}
              </button>
            ))}
          </div>
        </div>

        {/* Order type */}
        <div style={{ padding: "14px 16px 0" }}>
          <label style={lbl}>Order Type</label>
          <div style={{ display: "flex", gap: 6 }}>
            {[["Market", true], ["Limit", false]].map(([label, val]) => (
              <button key={label} onClick={() => setMkt(val)} style={{
                flex: 1, padding: "7px", fontSize: 11, fontWeight: 600, borderRadius: 7, cursor: "pointer",
                border: `1px solid ${mkt === val ? "rgba(56,189,248,0.3)" : "#1a2035"}`,
                background: mkt === val ? "rgba(56,189,248,0.08)" : "transparent",
                color: mkt === val ? "#38bdf8" : "#334155", transition: "all 0.15s",
              }}>{label}</button>
            ))}
          </div>
        </div>

        {/* Entry */}
        <div style={{ padding: "14px 16px 0" }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 5 }}>
            <label style={{ ...lbl, marginBottom: 0 }}>Entry Price</label>
            {!mkt && (
              <button onClick={() => setEntry(currentPrice.toFixed(cfg.dec))}
                style={{ fontSize: 9, color: "#38bdf8", background: "none", border: "none", cursor: "pointer" }}>
                At market
              </button>
            )}
          </div>
          <input type="number" style={{ ...inp, opacity: mkt ? 0.5 : 1 }}
            value={entry} readOnly={mkt}
            onChange={e => !mkt && setEntry(e.target.value)} placeholder="0.00"/>
        </div>

        {/* SL + TP side by side */}
        <div style={{ padding: "12px 16px 0", display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
          <div>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 5 }}>
              <label style={{ ...lbl, marginBottom: 0, color: "#7f1d1d" }}>Stop Loss</label>
              <button onClick={suggestSL} style={{ fontSize: 9, color: "rgba(239,68,68,0.5)", background: "none", border: "none", cursor: "pointer" }}>
                −1.5%
              </button>
            </div>
            <input type="number" style={{ ...inp, borderColor: sl ? "rgba(239,68,68,0.25)" : "#1a2035" }}
              value={sl} onChange={e => setSl(e.target.value)} placeholder="SL"/>
          </div>
          <div>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 5 }}>
              <label style={{ ...lbl, marginBottom: 0, color: "#064e3b" }}>Take Profit</label>
              <button onClick={suggestTP} style={{ fontSize: 9, color: "rgba(16,185,129,0.5)", background: "none", border: "none", cursor: "pointer" }}>
                +3%
              </button>
            </div>
            <input type="number" style={{ ...inp, borderColor: tp ? "rgba(16,185,129,0.25)" : "#1a2035" }}
              value={tp} onChange={e => setTp(e.target.value)} placeholder="TP"/>
          </div>
        </div>

        {/* Size */}
        <div style={{ padding: "12px 16px 0" }}>
          <label style={lbl}>Size</label>
          <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
            <input type="number" style={{ ...inp, flex: 1 }}
              value={size} onChange={e => setSize(e.target.value)} placeholder="1" min="0.01" step="0.01"/>
            <div style={{ display: "flex", gap: 3 }}>
              {["0.1","0.5","1","2"].map(s => (
                <button key={s} onClick={() => setSize(s)} style={{
                  width: 32, height: 32, borderRadius: 6, border: `1px solid ${size === s ? "rgba(56,189,248,0.3)" : "#1a2035"}`,
                  background: size === s ? "rgba(56,189,248,0.08)" : "transparent",
                  color: size === s ? "#38bdf8" : "#334155",
                  fontSize: 9, fontFamily: "monospace", cursor: "pointer", fontWeight: 700,
                }}>{s}</button>
              ))}
            </div>
          </div>
        </div>

        {/* Stats row — Est PnL + R:R */}
        {(estPnl !== null || rr !== null) && (
          <div style={{ margin: "12px 16px 0", borderRadius: 8, background: "#111827", border: "1px solid #1a2035", padding: "10px 12px" }}>
            <div style={{ display: "grid", gridTemplateColumns: rr ? "1fr 1fr" : "1fr", gap: 12 }}>
              {estPnl !== null && (
                <div>
                  <div style={{ fontSize: 9, color: "#334155", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.07em", marginBottom: 3 }}>Est. Profit</div>
                  <div style={{ fontFamily: "monospace", fontWeight: 700, fontSize: 14, color: parseFloat(estPnl) >= 0 ? "#34d399" : "#f87171" }}>
                    {parseFloat(estPnl) >= 0 ? "+" : ""}{estPnl}
                  </div>
                </div>
              )}
              {rr !== null && (
                <div>
                  <div style={{ fontSize: 9, color: "#334155", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.07em", marginBottom: 3 }}>R : R</div>
                  <div style={{ fontFamily: "monospace", fontWeight: 700, fontSize: 14, color: parseFloat(rr) >= 2 ? "#34d399" : parseFloat(rr) >= 1 ? "#fbbf24" : "#f87171" }}>
                    1 : {rr}
                  </div>
                </div>
              )}
            </div>
          </div>
        )}

        {/* Error */}
        {err && (
          <div style={{ margin: "10px 16px 0", display: "flex", alignItems: "center", gap: 8, borderRadius: 7, background: "rgba(239,68,68,0.06)", border: "1px solid rgba(239,68,68,0.15)", padding: "8px 12px", fontSize: 11, color: "#f87171" }}>
            <AlertCircle size={12}/>{err}
          </div>
        )}

        {/* Spacer */}
        <div style={{ flex: 1, minHeight: 16 }}/>
      </div>

      {/* Submit button — anchored to bottom */}
      <div style={{ padding: "12px 16px 16px", flexShrink: 0, borderTop: "1px solid #1a2035" }}>
        <button onClick={submit} style={{
          width: "100%", padding: "13px", borderRadius: 9, border: "none",
          fontSize: 13, fontWeight: 700, cursor: "pointer",
          display: "flex", alignItems: "center", justifyContent: "center", gap: 8,
          transition: "all 0.2s",
          background: flash
            ? "#10b981"
            : dir === "long"
            ? "linear-gradient(135deg,#059669,#10b981)"
            : "linear-gradient(135deg,#dc2626,#ef4444)",
          color: "#fff",
          boxShadow: flash
            ? "none"
            : dir === "long"
            ? "0 4px 20px rgba(16,185,129,0.3)"
            : "0 4px 20px rgba(239,68,68,0.3)",
          transform: flash ? "scale(0.97)" : "scale(1)",
          letterSpacing: "0.03em",
        }}>
          <Zap size={15}/>
          {flash ? "Opened!" : dir === "long" ? "Buy / Long" : "Sell / Short"}
        </button>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════
//  BOTTOM TABS  (Active Trades + Journal Preview)
// ═══════════════════════════════════════════════════════════════

function BottomTabs({ activeTrades, journalTrades, onCloseTrade }) {
  const [tab, setTab] = useState("positions");

  const recentJournal = useMemo(
    () => [...journalTrades].sort((a, b) => b.date - a.date).slice(0, 8),
    [journalTrades]
  );

  const TAB_H  = 36;
  const BODY_H = 160;

  const tabBtn = (id, label, count) => (
    <button onClick={() => setTab(id)} style={{
      display: "flex", alignItems: "center", gap: 6,
      padding: "0 16px", height: TAB_H, fontSize: 11, fontWeight: 600,
      cursor: "pointer", border: "none", background: "transparent",
      color: tab === id ? "#e2e8f0" : "#475569",
      borderBottom: tab === id ? "2px solid #38bdf8" : "2px solid transparent",
      transition: "all 0.15s",
    }}>
      {label}
      {count > 0 && (
        <span style={{
          fontSize: 9, fontWeight: 700, padding: "1px 5px", borderRadius: 10,
          background: tab === id ? "rgba(56,189,248,0.15)" : "rgba(71,85,105,0.3)",
          color: tab === id ? "#38bdf8" : "#64748b",
        }}>{count}</span>
      )}
    </button>
  );

  const th = {
    padding: "0 12px", height: 28, textAlign: "left",
    fontSize: 9, fontWeight: 700, color: "#334155",
    textTransform: "uppercase", letterSpacing: "0.07em",
    whiteSpace: "nowrap", background: "#0d1120",
  };
  const td = { padding: "8px 12px", fontSize: 11, borderBottom: "1px solid #0f1729" };

  return (
    <div style={{
      flexShrink: 0, borderTop: "1px solid #1a2035",
      background: "#0d1120", display: "flex", flexDirection: "column",
    }}>
      {/* Tab bar */}
      <div style={{ display: "flex", alignItems: "center", borderBottom: "1px solid #1a2035", height: TAB_H, flexShrink: 0 }}>
        {tabBtn("positions", "Positions", activeTrades.length)}
        {tabBtn("history",   "History",   Math.min(recentJournal.length, 99))}
        <div style={{ flex: 1 }}/>
        {tab === "positions" && activeTrades.length > 0 && (
          <div style={{ padding: "0 16px", fontSize: 10, fontFamily: "monospace" }}>
            <span style={{ color: "#475569" }}>Open PnL: </span>
            <span style={{
              fontWeight: 700,
              color: activeTrades.reduce((s, t) => s + t.pnl, 0) >= 0 ? "#34d399" : "#f87171",
            }}>
              {activeTrades.reduce((s, t) => s + t.pnl, 0) >= 0 ? "+" : ""}
              {activeTrades.reduce((s, t) => s + t.pnl, 0).toFixed(2)}
            </span>
          </div>
        )}
      </div>

      {/* Tab body */}
      <div style={{ height: BODY_H, overflow: "auto" }}>

        {/* ── POSITIONS ── */}
        {tab === "positions" && (
          activeTrades.length === 0 ? (
            <div style={{ display: "flex", alignItems: "center", justifyContent: "center", height: "100%", gap: 8, color: "#334155", fontSize: 12 }}>
              <Activity size={14}/> No open positions
            </div>
          ) : (
            <table style={{ width: "100%", borderCollapse: "collapse" }}>
              <thead>
                <tr>
                  {["Symbol","Type","Entry","Current","SL","TP","PnL","PnL%","Age",""].map(h => (
                    <th key={h} style={th}>{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {activeTrades.map(t => {
                  const w   = t.pnl >= 0;
                  const dec = SYMBOLS_CFG[t.symbol]?.dec ?? 2;
                  const sec = Math.floor((Date.now() - t.openedAt) / 1000);
                  const age = sec < 60 ? `${sec}s` : sec < 3600 ? `${Math.floor(sec/60)}m` : `${Math.floor(sec/3600)}h`;
                  return (
                    <tr key={t.id} style={{ background: "transparent" }}>
                      <td style={{ ...td, fontWeight: 700, color: "#e2e8f0", fontFamily: "monospace" }}>{t.symbol}</td>
                      <td style={td}>
                        <span style={{
                          padding: "1px 7px", borderRadius: 4,
                          fontSize: 9, fontWeight: 700, textTransform: "uppercase",
                          background: t.type === "long" ? "rgba(16,185,129,0.1)" : "rgba(239,68,68,0.1)",
                          color: t.type === "long" ? "#34d399" : "#f87171",
                          border: `1px solid ${t.type === "long" ? "rgba(16,185,129,0.2)" : "rgba(239,68,68,0.2)"}`,
                        }}>
                          {t.type === "long" ? "▲" : "▼"} {t.type}
                        </span>
                      </td>
                      <td style={{ ...td, fontFamily: "monospace", color: "#64748b" }}>{t.entryPrice.toFixed(dec)}</td>
                      <td style={{ ...td, fontFamily: "monospace", fontWeight: 700, color: w ? "#34d399" : "#f87171" }}>{t.currentPrice.toFixed(dec)}</td>
                      <td style={{ ...td, fontFamily: "monospace", color: "rgba(248,113,113,0.6)" }}>{t.stopLoss != null ? t.stopLoss.toFixed(dec) : "—"}</td>
                      <td style={{ ...td, fontFamily: "monospace", color: "rgba(52,211,153,0.6)" }}>{t.takeProfit != null ? t.takeProfit.toFixed(dec) : "—"}</td>
                      <td style={{ ...td, fontFamily: "monospace", fontWeight: 700, color: w ? "#34d399" : "#f87171" }}>{w ? "+" : ""}{t.pnl.toFixed(2)}</td>
                      <td style={td}>
                        <span style={{
                          padding: "1px 5px", borderRadius: 4, fontSize: 9, fontFamily: "monospace",
                          background: w ? "rgba(16,185,129,0.08)" : "rgba(239,68,68,0.08)",
                          color: w ? "#34d399" : "#f87171",
                        }}>{w ? "+" : ""}{t.pnlPercent.toFixed(2)}%</span>
                      </td>
                      <td style={{ ...td, fontFamily: "monospace", color: "#334155" }}>{age}</td>
                      <td style={td}>
                        <button onClick={() => onCloseTrade(t.id)} style={{
                          padding: "2px 10px", borderRadius: 5, fontSize: 10, fontWeight: 600,
                          border: "1px solid #1a2d40", background: "transparent",
                          color: "#475569", cursor: "pointer", transition: "all 0.12s",
                        }}>Close</button>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          )
        )}

        {/* ── HISTORY ── */}
        {tab === "history" && (
          recentJournal.length === 0 ? (
            <div style={{ display: "flex", alignItems: "center", justifyContent: "center", height: "100%", gap: 8, color: "#334155", fontSize: 12 }}>
              <BookOpen size={14}/> No closed trades yet
            </div>
          ) : (
            <table style={{ width: "100%", borderCollapse: "collapse" }}>
              <thead>
                <tr>
                  {["Date","Symbol","Type","Entry","Exit","PnL","Strategy","Tags"].map(h => (
                    <th key={h} style={th}>{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {recentJournal.map((t, i) => {
                  const w = t.pnl >= 0;
                  return (
                    <tr key={t.id} style={{ background: i % 2 === 0 ? "transparent" : "rgba(15,23,42,0.3)" }}>
                      <td style={{ ...td, color: "#334155", fontFamily: "monospace", whiteSpace: "nowrap" }}>
                        {new Date(t.date).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                      </td>
                      <td style={{ ...td, fontWeight: 700, color: "#94a3b8" }}>{t.symbol}</td>
                      <td style={td}>
                        <span style={{
                          padding: "1px 6px", borderRadius: 4, fontSize: 9, fontWeight: 700, textTransform: "uppercase",
                          background: t.type === "long" ? "rgba(16,185,129,0.08)" : "rgba(239,68,68,0.08)",
                          color: t.type === "long" ? "#34d399" : "#f87171",
                          border: `1px solid ${t.type === "long" ? "rgba(16,185,129,0.15)" : "rgba(239,68,68,0.15)"}`,
                        }}>{t.type}</span>
                      </td>
                      <td style={{ ...td, fontFamily: "monospace", color: "#475569" }}>{t.entryPrice.toLocaleString()}</td>
                      <td style={{ ...td, fontFamily: "monospace", color: "#475569" }}>{t.exitPrice.toLocaleString()}</td>
                      <td style={{ ...td, fontFamily: "monospace", fontWeight: 700, color: w ? "#34d399" : "#f87171" }}>
                        {w ? "+" : ""}{t.pnl.toFixed(2)}
                      </td>
                      <td style={{ ...td, color: "#475569", fontSize: 10 }}>{t.strategy ?? "—"}</td>
                      <td style={{ ...td }}>
                        <div style={{ display: "flex", gap: 3, flexWrap: "wrap" }}>
                          {(t.tags ?? []).slice(0, 2).map(tag => {
                            const clr = tagColor(tag);
                            return (
                              <span key={tag} style={{
                                padding: "1px 5px", borderRadius: 20, fontSize: 8, fontWeight: 700,
                                background: clr.bg, border: `1px solid ${clr.border}`, color: clr.text,
                              }}>{tag}</span>
                            );
                          })}
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          )
        )}
      </div>
    </div>
  );
}


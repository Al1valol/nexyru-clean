function StrategyDetail({ strategy, session, onBack, onCopy, onEdit }) {
  const p      = strategy.performance ?? {};
  const isOwner = strategy.createdBy === session.username;
  const isPos   = (p.pnl ?? 0) >= 0;
  const hasData = p.totalTrades > 0;

  const condLabel = (cond) => STRATEGY_CONDITIONS.find(c => c.value === cond)?.label ?? cond;

  return (
    <div style={{ maxWidth: 760, margin: "0 auto", display: "flex", flexDirection: "column", gap: 20 }}>
      {/* Back */}
      <button onClick={onBack} style={{ display: "flex", alignItems: "center", gap: 6, background: "none", border: "none", color: "#475569", cursor: "pointer", fontSize: 12, fontWeight: 600, padding: 0, width: "fit-content" }}>

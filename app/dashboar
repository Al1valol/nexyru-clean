function RuleBuilder({ rules, onChange }) {
  const addRule = () => {
    onChange([...rules, {
      id:        `r_${Date.now()}`,
      condition: "price_breaks_high",
      value:     "20",
      action:    "buy",
    }]);
  };

  const updateRule = (id, field, value) => {
    onChange(rules.map(r => r.id === id ? { ...r, [field]: value } : r));
  };

  const removeRule = (id) => {
    onChange(rules.filter(r => r.id !== id));
  };

  const sel = {
    padding: "7px 10px", borderRadius: 7,
    background: "#111827", border: "1px solid #1a2035",
    fontSize: 11, color: "#e2e8f0", cursor: "pointer", outline: "none",

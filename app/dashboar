function RiskSettingsPanel({ bot, onChange }) {
  const inp = {
    width: "100%", padding: "7px 10px", borderRadius: 7,
    background: "#111827", border: "1px solid #1a2035",
    fontSize: 12, color: "#e2e8f0", outline: "none",
    boxSizing: "border-box", fontFamily: "monospace",
  };
  const lbl = { fontSize: 9, color: "#475569", textTransform: "uppercase", letterSpacing: "0.07em", marginBottom: 5, display: "block" };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
        <div>
          <label style={lbl}>Risk per trade %</label>
          <div style={{ position: "relative" }}>
            <input type="number" style={inp} min="0.1" max="10" step="0.1"
              value={bot.riskPct ?? 1}
              onChange={e => onChange({ riskPct: parseFloat(e.target.value) || 1 })}
            />
            <span style={{ position: "absolute", right: 8, top: "50%", transform: "translateY(-50%)", fontSize: 10, color: "#475569" }}>%</span>
          </div>
        </div>
        <div>
          <label style={lbl}>Max daily loss %</label>
          <div style={{ position: "relative" }}>
            <input type="number" style={inp} min="1" max="50" step="0.5"
              value={bot.maxDailyLoss ?? 3}
              onChange={e => onChange({ maxDailyLoss: parseFloat(e.target.value) || 3 })}
            />
            <span style={{ position: "absolute", right: 8, top: "50%", transform: "translateY(-50%)", fontSize: 10, color: "#475569" }}>%</span>
          </div>
        </div>
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
        <div>
          <label style={lbl}>Max trades / day</label>
          <input type="number" style={inp} min="1" max="50"
            value={bot.maxDailyTrades ?? 5}
            onChange={e => onChange({ maxDailyTrades: parseInt(e.target.value) || 5 })}
          />
        </div>
        <div>
          <label style={lbl}>Cooldown (seconds)</label>
          <input type="number" style={inp} min="10" max="3600"
            value={Math.round((bot.cooldownMs ?? BOT_COOLDOWN_MS) / 1000)}
            onChange={e => onChange({ cooldownMs: (parseInt(e.target.value) || 30) * 1000 })}
          />
        </div>
      </div>
      {/* Risk summary */}
      <div style={{ padding: "8px 10px", borderRadius: 7, background: "rgba(56,189,248,0.05)", border: "1px solid rgba(56,189,248,0.12)", fontSize: 10, color: "#475569", lineHeight: 1.6 }}>
        Bot will stop trading today if it loses <strong style={{ color: "#f87171" }}>{bot.maxDailyLoss ?? 3}%</strong> or takes <strong style={{ color: "#fbbf24" }}>{bot.maxDailyTrades ?? 5}</strong> trades. Each trade risks <strong style={{ color: "#38bdf8" }}>{bot.riskPct ?? 1}%</strong> of account.
      </div>
    </div>
  );
}

function BotCard({ bot, strategy, activeTrade, onToggle, onDelete, onViewLog, onUpdateBot }) {
  const [showRisk, setShowRisk] = useState(false);
  const isActive  = bot.isActive;
  const hasTrade  = !!activeTrade;
  const tradePnl  = activeTrade?.pnl ?? 0;
  const isSemi    = bot.mode === "semi";
  const today     = new Date().toDateString();
  const todayOk   = bot.todayDate === today;
  const todayTrades = todayOk ? (bot.todayTrades ?? 0) : 0;
  const todayPnl   = todayOk ? (bot.todayPnl ?? 0) : 0;
  const maxDD      = bot.maxDailyLoss ?? 3;
  const maxT       = bot.maxDailyTrades ?? 5;
  const dailyLimitHit = !isSemi && (todayTrades >= maxT || (todayPnl < 0 && Math.abs(todayPnl) >= maxDD));

  const statusColor  = dailyLimitHit ? "#f59e0b" : isActive ? "#34d399" : "#475569";
  const statusLabel  = dailyLimitHit ? "Paused (limit)" : isActive ? "Running" : "Stopped";

  return (
    <div style={{
      borderRadius: 12,
      border: `1px solid ${isActive && !dailyLimitHit ? "rgba(52,211,153,0.25)" : "#1a2035"}`,
      background: "#0d1120", overflow: "hidden",
      transition: "border-color 0.2s",
    }}>
      {/* Header */}
      <div style={{ padding: "12px 16px", borderBottom: "1px solid #111827" }}>
        <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between", gap: 8 }}>
          <div style={{ flex: 1 }}>
            {/* Status + mode badges */}
            <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 5 }}>
              <span style={{ width: 7, height: 7, borderRadius: "50%", background: statusColor, display: "inline-block", animation: isActive && !dailyLimitHit ? "pulse 1.5s infinite" : "none" }}/>
              <span style={{ fontSize: 9, fontWeight: 700, color: statusColor, textTransform: "uppercase", letterSpacing: "0.08em" }}>{statusLabel}</span>
              {/* Mode badge */}
              <span style={{
                fontSize: 9, fontWeight: 700, padding: "1px 7px", borderRadius: 20,
                background: isSemi ? "rgba(251,191,36,0.1)" : "rgba(99,102,241,0.1)",
                border: `1px solid ${isSemi ? "rgba(251,191,36,0.3)" : "rgba(99,102,241,0.3)"}`,
                color: isSemi ? "#fbbf24" : "#818cf8",
              }}>
                {isSemi ? "⚡ Semi-Auto" : "🤖 Full-Auto"}
              </span>
              {hasTrade && <span style={{ fontSize: 9, fontWeight: 700, padding: "1px 6px", borderRadius: 20, background: "rgba(56,189,248,0.1)", border: "1px solid rgba(56,189,248,0.2)", color: "#38bdf8" }}>Trade Open</span>}
            </div>

            <div style={{ fontSize: 13, fontWeight: 700, color: "#e2e8f0", lineHeight: 1.3 }}>
              {strategy?.name ?? "Unknown Strategy"}
            </div>
            <div style={{ fontSize: 10, color: "#475569", marginTop: 3, fontFamily: "monospace" }}>
              {bot.symbol} · SL {(BOT_SL_PCT*100).toFixed(1)}% · TP {(BOT_TP_PCT*100).toFixed(1)}%
            </div>
          </div>

          {/* Toggle */}
          <button onClick={() => onToggle(bot.id)} style={{
            display: "flex", alignItems: "center", gap: 5, padding: "7px 14px", borderRadius: 8,
            border: `1px solid ${isActive ? "rgba(239,68,68,0.35)" : "rgba(52,211,153,0.35)"}`,
            background: isActive ? "rgba(239,68,68,0.08)" : "rgba(52,211,153,0.08)",
            color: isActive ? "#f87171" : "#34d399",
            fontSize: 11, fontWeight: 700, cursor: "pointer", flexShrink: 0,
          }}>
            {isActive ? <><Square size={10}/> Stop</> : <><Play size={10}/> Start</>}
          </button>
        </div>

        {/* Mode toggle */}
        <div style={{ display: "flex", marginTop: 10, borderRadius: 7, overflow: "hidden", border: "1px solid #1a2035" }}>
          {[
            { id: "semi", label: "⚡ Semi-Auto", desc: "You confirm trades" },
            { id: "full", label: "🤖 Full-Auto", desc: "Bot trades automatically" },
          ].map(m => (
            <button key={m.id} onClick={() => onUpdateBot(bot.id, { mode: m.id })} style={{
              flex: 1, padding: "7px 8px", border: "none", cursor: "pointer",
              background: bot.mode === m.id
                ? (m.id === "semi" ? "rgba(251,191,36,0.1)" : "rgba(99,102,241,0.1)")
                : "transparent",
              borderBottom: bot.mode === m.id
                ? `2px solid ${m.id === "semi" ? "#fbbf24" : "#818cf8"}`
                : "2px solid transparent",
              transition: "all 0.15s",
            }}>
              <div style={{ fontSize: 10, fontWeight: 700, color: bot.mode === m.id ? (m.id === "semi" ? "#fbbf24" : "#818cf8") : "#475569" }}>{m.label}</div>
              <div style={{ fontSize: 8, color: "#334155", marginTop: 1 }}>{m.desc}</div>
            </button>
          ))}
        </div>
      </div>

      {/* Stats row */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", borderBottom: "1px solid #111827" }}>
        {[
          { label: "Trades",   val: String(bot.tradesExecuted ?? 0),                                                           color: "#94a3b8" },
          { label: "Total PnL",val: (bot.tradesExecuted ?? 0) > 0 ? `${(bot.totalPnl??0)>=0?"+":""}${(bot.totalPnl??0).toFixed(2)}` : "—", color: (bot.totalPnl??0)>=0 ? "#34d399" : "#f87171" },
          { label: "Today",    val: `${todayTrades}/${maxT}`,                                                                  color: todayTrades >= maxT ? "#f59e0b" : "#94a3b8" },
          { label: "Open PnL", val: hasTrade ? `${tradePnl>=0?"+":""}${tradePnl.toFixed(2)}` : "—",                           color: hasTrade ? (tradePnl>=0?"#34d399":"#f87171") : "#334155" },
        ].map(({ label, val, color }) => (
          <div key={label} style={{ padding: "8px 10px", textAlign: "center", borderRight: "1px solid #111827" }}>
            <div style={{ fontSize: 8, color: "#334155", textTransform: "uppercase", letterSpacing: "0.07em", marginBottom: 3 }}>{label}</div>
            <div style={{ fontSize: 12, fontWeight: 700, fontFamily: "monospace", color }}>{val}</div>
          </div>
        ))}
      </div>

      {/* Risk settings panel (collapsible) */}
      <div style={{ borderBottom: "1px solid #111827" }}>
        <button onClick={() => setShowRisk(v => !v)} style={{
          width: "100%", display: "flex", alignItems: "center", justifyContent: "space-between",
          padding: "8px 14px", border: "none", background: "transparent", cursor: "pointer",
          fontSize: 10, fontWeight: 700, color: "#475569",
        }}>
          <span style={{ display: "flex", alignItems: "center", gap: 5 }}>
            <Shield size={10}/> Risk Settings
            {dailyLimitHit && <span style={{ fontSize: 8, color: "#f59e0b", background: "rgba(245,158,11,0.1)", padding: "1px 5px", borderRadius: 10 }}>LIMIT HIT</span>}
          </span>
          <ChevronDown size={10} style={{ transform: showRisk ? "rotate(180deg)" : "none", transition: "transform 0.2s" }}/>
        </button>
        {showRisk && (
          <div style={{ padding: "0 14px 14px" }}>
            <RiskSettingsPanel bot={bot} onChange={patch => onUpdateBot(bot.id, patch)}/>
          </div>
        )}
      </div>

      {/* Log + equity sparkline */}
      {(bot.tradeHistory?.length ?? 0) > 1 && (() => {
        const hist = [...(bot.tradeHistory ?? [])].reverse();
        let cum = 0;
        const points = hist.map(t => { cum += t.pnl; return cum; });
        const minP = Math.min(...points, 0), maxP = Math.max(...points, 0);
        const range = maxP - minP || 1;
        const W = 180, H = 24;
        const toX = i => (i / (points.length - 1)) * W;
        const toY = v => H - ((v - minP) / range) * H;
        const lastPos = points[points.length - 1] >= 0;
        return (
          <div style={{ padding: "6px 14px", borderBottom: "1px solid #111827", display: "flex", alignItems: "center", gap: 10 }}>
            <svg width={W} height={H} style={{ flex: 1 }}>
              <polyline points={points.map((v, i) => `${toX(i)},${toY(v)}`).join(" ")}
                fill="none" stroke={lastPos ? "#10b981" : "#ef4444"} strokeWidth={1.5}/>
              {minP < 0 && maxP > 0 && <line x1={0} y1={toY(0)} x2={W} y2={toY(0)} stroke="#1a2035" strokeWidth={1} strokeDasharray="3 2"/>}
            </svg>
            <span style={{ fontSize: 9, color: "#334155", flexShrink: 0 }}>{points.length} trades</span>
          </div>
        );
      })()}

      {/* Last log entry */}
      {bot.log?.length > 0 && (
        <div style={{ padding: "6px 14px", fontSize: 9, color: "#475569", fontFamily: "monospace", borderBottom: "1px solid #111827", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
          {bot.log[0]}
        </div>
      )}

      {/* Footer */}
      <div style={{ padding: "8px 14px", display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <button onClick={() => onViewLog(bot)} style={{ display: "flex", alignItems: "center", gap: 5, background: "none", border: "none", color: "#475569", cursor: "pointer", fontSize: 10, fontWeight: 600 }}>
          <RefreshCw size={10}/> Log ({bot.log?.length ?? 0})
        </button>
        <button onClick={() => onDelete(bot.id)} style={{ display: "flex", alignItems: "center", gap: 5, background: "none", border: "none", color: "#334155", cursor: "pointer", fontSize: 10 }}>
          <Trash size={10}/> Delete
        </button>
      </div>
    </div>
  );

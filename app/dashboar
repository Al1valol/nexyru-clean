              <span style={{ fontSize: 8, color: "#334155" }}>{SYMBOLS_CFG[sym]?.label}</span>
            </div>
            <span style={{ fontSize: 18, fontWeight: 700, fontFamily: "monospace", color: priceUp ? "#34d399" : "#f87171", transition: "color 0.3s" }}>
              {curPrice.toFixed(cfg.dec)}
            </span>
          </div>
          <div style={{
            padding: "3px 8px", borderRadius: 6,
            background: priceUp ? "rgba(16,185,129,0.1)" : "rgba(239,68,68,0.1)",
            border: `1px solid ${priceUp ? "rgba(16,185,129,0.2)" : "rgba(239,68,68,0.2)"}`,
            display: "flex", alignItems: "center", gap: 3,
            fontSize: 10, fontFamily: "monospace",
            color: priceUp ? "#34d399" : "#f87171",
          }}>
            {priceUp ? <TrendingUp size={10}/> : <TrendingDown size={10}/>}
            {priceUp ? "+" : ""}{pct}%
          </div>
        </div>

        {/* ── Nav ── */}
        <div style={{ display: "flex", alignItems: "center", gap: 2, padding: "0 16px", borderLeft: "1px solid #1a2035", height: "100%" }}>
          {[
            { id: "dashboard",  label: "Dashboard",  icon: <Activity size={12}/> },
            { id: "journal",    label: "Journal",    icon: <BookOpen  size={12}/> },
            { id: "strategies", label: "Strategies", icon: <Layers    size={12}/> },
            { id: "bots",       label: "Bots",       icon: <Bot       size={12}/>, badge: bots.filter(b => b.isActive).length },
          ].map(({ id, label, icon, badge }) => (
            <button key={id} onClick={() => setDeskTab(id)} style={{
              display: "flex", alignItems: "center", gap: 6,
              padding: "5px 12px", borderRadius: 7,
              fontSize: 11, fontWeight: 600, cursor: "pointer",
              border: "none", transition: "all 0.15s",
              background: desktopTab === id ? "rgba(56,189,248,0.12)" : "transparent",
              color:      desktopTab === id ? "#38bdf8" : "#64748b",
              position: "relative",
            }}>
              {icon}{label}
              {badge > 0 && (
                <span style={{
                  position: "absolute", top: 2, right: 2,
                  width: 8, height: 8, borderRadius: "50%",
                  background: "#34d399", animation: "pulse 1.5s infinite",
                }}/>
              )}
            </button>
          ))}
        </div>

        {/* ── Account ── */}
        <div style={{ padding: "0 12px", borderLeft: "1px solid #1a2035", height: "100%", display: "flex", alignItems: "center" }}>
          <AccountMenu session={session} onLogout={onLogout}/>
        </div>
      </header>

      {/* ╔══════════════════════════════════════════════════════════╗
          ║  DASHBOARD TAB                                           ║
          ╚══════════════════════════════════════════════════════════╝ */}
      {desktopTab === "dashboard" && (
        <div style={{ display: "flex", flex: 1, minHeight: 0, overflow: "hidden" }}>
          <div style={{ display: "flex", flexDirection: "column", flex: 1, minWidth: 0, minHeight: 0 }}>
            <div style={{ flex: 1, minHeight: 0, display: "flex", flexDirection: "column", borderRight: "1px solid #1a2035" }}>
              {/* Chart header */}
              <div style={{ display: "flex", alignItems: "center", gap: 8, padding: "6px 16px", borderBottom: "1px solid #1a2035", background: "#0d1120", flexShrink: 0, height: 44 }}>
                {/* Symbol picker dropdown */}
                <SymbolPicker value={sym} onChange={setSym}/>

                {/* Asset type badge */}
                {(() => {
                  const cat = SYMBOLS_CFG[sym]?.category;
                  const catColors = { crypto: "#38bdf8", stocks: "#34d399", futures: "#fbbf24", forex: "#a78bfa" };
                  const catLabels = { crypto: "Crypto · Live", stocks: "Stock · Sim", futures: "Futures · Sim", forex: "Forex · Sim" };
                  return cat ? (
                    <span style={{ fontSize: 9, fontWeight: 700, color: catColors[cat], background: `${catColors[cat]}12`, border: `1px solid ${catColors[cat]}30`, padding: "2px 7px", borderRadius: 20 }}>
                      {catLabels[cat]}
                    </span>
                  ) : null;
                })()}

                <div style={{ display: "flex", gap: 1, marginLeft: 4, borderRadius: 5, overflow: "hidden", border: "1px solid #1a2035" }}>
                  {TF_LIST.map(t => (
                    <button key={t} onClick={() => setTf(t)} style={{
                      padding: "2px 8px", fontSize: 9, fontFamily: "monospace",
                      border: "none", cursor: "pointer", transition: "all 0.12s",
                      background: tf === t ? "#1a2035" : "transparent",
                      color: tf === t ? "#94a3b8" : "#475569",
                      fontWeight: tf === t ? 700 : 400,
                    }}>{t}</button>
                  ))}
                </div>
                <div style={{ flex: 1 }}/>
                {/* Live/Sim toggle — reflects actual dataSource */}
                <button
                  onClick={() => {
                    if (apiReachable === false && forceSim) return;
                    setForceSim(f => !f);
                  }}
                  title={apiReachable === false ? "Binance API unreachable in this environment" : forceSim ? "Switch to live Binance data" : "Switch to simulated data"}
                  style={{
                    display: "flex", alignItems: "center", gap: 5,
                    padding: "3px 10px", borderRadius: 20, fontSize: 9,
                    fontWeight: 700,
                    cursor: apiReachable === false && forceSim ? "not-allowed" : "pointer",
                    opacity: apiReachable === false && forceSim ? 0.5 : 1,
                    border: `1px solid ${dataSource === "live" ? "rgba(16,185,129,0.4)" : apiReachable === false ? "rgba(239,68,68,0.35)" : "rgba(251,191,36,0.4)"}`,
                    background: dataSource === "live" ? "rgba(16,185,129,0.1)" : apiReachable === false ? "rgba(239,68,68,0.08)" : "rgba(251,191,36,0.1)",
                    color: dataSource === "live" ? "#34d399" : apiReachable === false ? "#f87171" : "#fbbf24",
                    transition: "all 0.2s",
                  }}
                >
                  {loading ? (
                    <span style={{ display: "inline-block", width: 7, height: 7, border: "1.5px solid currentColor", borderTopColor: "transparent", borderRadius: "50%", animation: "spin 0.7s linear infinite" }}/>
                  ) : (
                    <span style={{ width: 5, height: 5, borderRadius: "50%", background: "currentColor", display: "inline-block", animation: dataSource === "live" ? "pulse 1.5s infinite" : "none" }}/>
                  )}
                  {loading ? "…" : dataSource === "live" ? "LIVE" : apiReachable === false ? "BLOCKED" : "SIM"}
                </button>
              </div>
              {/* Bot quick panel — one-tap toggle strip */}
              <BotQuickPanel
                bots={bots}
                strategies={allStrategies}
                activeTrades={activeTrades}
                onToggle={toggleBot}
                onGoToBots={() => setDeskTab("bots")}
                sym={sym}
              />
              {/* Canvas */}
              <div style={{ flex: 1, minHeight: 0 }}>
                <CandleChart candles={candles} livePrice={curPrice} activeTrades={activeTrades} journalTrades={journalTrades} symbol={sym} dec={cfg.dec} tf={tf}/>
              </div>
            </div>
            <BottomTabs activeTrades={activeTrades} journalTrades={journalTrades} onCloseTrade={closeTrade}/>
          </div>
          <div style={{ width: 284, flexShrink: 0, display: "flex", flexDirection: "column", borderLeft: "1px solid #1a2035", background: "#0d1120" }}>
            <OrderForm symbol={sym} currentPrice={curPrice} onOpen={openTrade}/>
          </div>
        </div>
      )}

      {/* ╔══════════════════════════════════════════════════════════╗
          ║  JOURNAL TAB                                             ║
          ╚══════════════════════════════════════════════════════════╝ */}
      {desktopTab === "journal" && (
        <div style={{ flex: 1, overflow: "auto", background: "#0b0e17" }}>
          <div style={{ maxWidth: 1200, margin: "0 auto", padding: "24px" }}>
            <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 24 }}>
              <div style={{ width: 36, height: 36, borderRadius: 9, background: "rgba(56,189,248,0.08)", border: "1px solid rgba(56,189,248,0.15)", display: "flex", alignItems: "center", justifyContent: "center" }}>
                <BookOpen size={16} style={{ color: "#38bdf8" }}/>
              </div>
              <div>
                <div style={{ fontSize: 16, fontWeight: 700, color: "#f1f5f9" }}>Trade Journal</div>
                <div style={{ fontSize: 10, color: "#475569", marginTop: 3 }}>{journalTrades.length} trades recorded</div>
              </div>
            </div>
            <JournalTab
              trades={journalTrades}
              onRemove={id => setJournalTrades(p => p.filter(t => t.id !== id))}
              onUpdate={updated => setJournalTrades(p => p.map(t => t.id === updated.id ? updated : t))}
              onLoadDemo={() => setJournalTrades(makeDemoTrades())}
            />
          </div>
        </div>
      )}

      {desktopTab === "bots" && (
        <div style={{ flex: 1, overflow: "auto", background: "#0b0e17" }}>
          <div style={{ maxWidth: 1200, margin: "0 auto", padding: "28px 24px" }}>
            <BotsPage
              session={session}
              bots={bots}
              strategies={allStrategies}
              activeTrades={activeTrades}
              onToggle={toggleBot}
              onDelete={deleteBot}
                onUpdateBot={updateBot}
            />
          </div>
        </div>
      )}

      {desktopTab === "strategies" && (
        <div style={{ flex: 1, overflow: "auto", background: "#0b0e17" }}>
          <div style={{ maxWidth: 1200, margin: "0 auto", padding: "28px 24px" }}>
            <StrategiesPage session={session} bots={bots} onLaunchBot={(strategy, stopExisting, opts, symbol) => {
              const existing = bots.find(b => b.strategyId === strategy.id);
              if (existing) {
                toggleBot(existing.id);
              } else {
                const bot = createBot(strategy.id, strategy.name, symbol ?? sym, opts ?? {});
                setTimeout(() => toggleBot(bot.id), 80);
              }
            }}/>
          </div>
        </div>
      )}

      {/* Semi-auto trade confirmation toast — global, shown over everything */}
      {pendingSignal && (
        <TradeConfirmToast
          signal={pendingSignal}
          timeLeft={toastTimer}
          onApprove={handleApproveSignal}
          onReject={handleRejectSignal}
        />
      )}

      <style>{`
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
        @keyframes slideUp { from { opacity:0; transform:translateY(20px) } to { opacity:1; transform:translateY(0) } }
        @keyframes spin { to { transform: rotate(360deg) } }
        * { box-sizing: border-box; }
        input[type=number]::-webkit-inner-spin-button,
        input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
        input[type=number] { -moz-appearance: textfield; }
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #1e2d40; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #263d55; }
        button { font-family: inherit; }
        select { font-family: inherit; }
      `}</style>
    </div>
  );
}
function SymbolPicker({ value, onChange, compact = false }) {
  const [open, setOpen]     = useState(false);
  const [search, setSearch] = useState("");
  const [cat, setCat]       = useState("all");
  const ref = useRef(null);

  const cfg = SYMBOLS_CFG[value];
  const catColor = {
    crypto:  "#38bdf8",
    stocks:  "#34d399",
    futures: "#fbbf24",
    forex:   "#a78bfa",
  };

  // Filter symbols by category and search
  const filtered = SYM_LIST.filter(s => {
    const c = SYMBOLS_CFG[s];
    if (cat !== "all" && c.category !== cat) return false;
    if (search && !s.toLowerCase().includes(search.toLowerCase()) &&
        !c.label.toLowerCase().includes(search.toLowerCase())) return false;
    return true;
  });

  // Close on outside click
  useEffect(() => {
    if (!open) return;
    const fn = e => { if (ref.current && !ref.current.contains(e.target)) setOpen(false); };
    document.addEventListener("mousedown", fn);
    return () => document.removeEventListener("mousedown", fn);
  }, [open]);

  const color = catColor[cfg?.category] ?? "#94a3b8";

  return (
    <div ref={ref} style={{ position: "relative" }}>
      {/* Trigger button */}
      <button
        onClick={() => setOpen(v => !v)}
        style={{
          display: "flex", alignItems: "center", gap: 6,
          padding: compact ? "3px 10px" : "5px 12px",
          borderRadius: 8, cursor: "pointer",
          border: `1px solid ${open ? color : "rgba(255,255,255,0.08)"}`,
          background: open ? `${color}18` : "rgba(255,255,255,0.04)",
          transition: "all 0.15s",
        }}
      >
        {/* Category dot */}
        <span style={{ width: 6, height: 6, borderRadius: "50%", background: color, display: "inline-block", flexShrink: 0 }}/>
        <span style={{ fontSize: compact ? 11 : 13, fontWeight: 700, fontFamily: "monospace", color: "#e2e8f0" }}>
          {value}
        </span>
        {!compact && (
          <span style={{ fontSize: 9, color: "#475569" }}>{cfg?.label}</span>
        )}
        <ChevronDown size={10} style={{ color: "#475569", marginLeft: 2 }}/>
      </button>

      {/* Dropdown */}
      {open && (
        <div style={{
          position: "absolute", top: "calc(100% + 6px)", left: 0,
          width: 320, maxHeight: 400, borderRadius: 12,
          border: "1px solid #1a2035", background: "#0d1120",
          boxShadow: "0 16px 48px rgba(0,0,0,0.5)",
          zIndex: 100, overflow: "hidden", display: "flex", flexDirection: "column",
        }}>
          {/* Search */}
          <div style={{ padding: "10px 12px", borderBottom: "1px solid #1a2035" }}>
            <input
              autoFocus
              value={search}
              onChange={e => setSearch(e.target.value)}
              placeholder="Search symbol or name..."
              style={{
                width: "100%", padding: "7px 10px", borderRadius: 7,
                background: "#111827", border: "1px solid #1a2035",
                fontSize: 12, color: "#e2e8f0", outline: "none",
                boxSizing: "border-box",
              }}
            />
          </div>

          {/* Category tabs */}
          <div style={{ display: "flex", borderBottom: "1px solid #1a2035", padding: "4px 8px", gap: 2 }}>
            {[{ id: "all", label: "All" }, ...ASSET_CATEGORIES].map(c => (
              <button key={c.id} onClick={() => setCat(c.id)} style={{
                padding: "4px 10px", borderRadius: 6, fontSize: 10, fontWeight: 700,
                cursor: "pointer", border: "none",
                background: cat === c.id ? "rgba(56,189,248,0.12)" : "transparent",
                color: cat === c.id ? "#38bdf8" : "#475569",
              }}>
                {c.emoji} {c.label}
              </button>
            ))}
          </div>

          {/* Symbol list */}
          <div style={{ overflowY: "auto", maxHeight: 280 }}>
            {ASSET_CATEGORIES
              .filter(c => cat === "all" || c.id === cat)
              .map(c => {
                const syms = filtered.filter(s => SYMBOLS_CFG[s].category === c.id);
                if (!syms.length) return null;
                return (
                  <div key={c.id}>
                    <div style={{ padding: "6px 14px 4px", fontSize: 9, fontWeight: 700, color: "#334155", textTransform: "uppercase", letterSpacing: "0.08em", display: "flex", alignItems: "center", gap: 5 }}>
                      <span style={{ width: 5, height: 5, borderRadius: "50%", background: catColor[c.id], display: "inline-block" }}/>
                      {c.label}
                      {c.id !== "crypto" && <span style={{ fontSize: 8, color: "#334155", fontWeight: 400 }}> · simulated</span>}
                    </div>
                    {syms.map(s => {
                      const sc = SYMBOLS_CFG[s];
                      const isLive = !!sc.coinbase;
                      return (
                        <button key={s} onClick={() => { onChange(s); setOpen(false); setSearch(""); }} style={{
                          width: "100%", display: "flex", alignItems: "center", gap: 10,
                          padding: "8px 14px", border: "none", cursor: "pointer", textAlign: "left",
                          background: s === value ? "rgba(56,189,248,0.06)" : "transparent",
                          borderLeft: s === value ? "2px solid #38bdf8" : "2px solid transparent",
                          transition: "background 0.1s",
                        }}
                        onMouseEnter={e => e.currentTarget.style.background = "rgba(255,255,255,0.04)"}
                        onMouseLeave={e => e.currentTarget.style.background = s === value ? "rgba(56,189,248,0.06)" : "transparent"}
                        >
                          <span style={{ fontFamily: "monospace", fontSize: 12, fontWeight: 700, color: "#e2e8f0", minWidth: 70 }}>{s}</span>
                          <span style={{ fontSize: 11, color: "#64748b", flex: 1 }}>{sc.label}</span>
                          <div style={{ display: "flex", alignItems: "center", gap: 4 }}>
                            {sc.suffix && <span style={{ fontSize: 8, color: "#334155", background: "#111827", padding: "1px 5px", borderRadius: 4 }}>{sc.suffix}</span>}
                            {isLive && <span style={{ fontSize: 8, fontWeight: 700, color: "#34d399" }}>●LIVE</span>}
                          </div>
                        </button>
                      );
                    })}
                  </div>
                );
              })}
            {filtered.length === 0 && (
              <div style={{ padding: "20px", textAlign: "center", color: "#334155", fontSize: 12 }}>
                No symbols match "{search}"
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
//  CANDLE CHART  — canvas rendering + SVG overlays + pan/zoom
// ─────────────────────────────────────────────────────────────
function CandleChart({ candles, livePrice, activeTrades, journalTrades, symbol, dec, tf }) {
  const canvasRef    = useRef(null);
  const containerRef = useRef(null);
  const [dims, setDims] = useState({ w: 0, h: 0 });

  // ── View state: offset (candles panned left) + zoom ──
  const [offset, setOffset]   = useState(0);   // bars scrolled from right
  const [zoom,   setZoom]     = useState(1.0);  // 1 = normal, >1 = more candles visible
  const isDragging = useRef(false);
  const dragStart  = useRef({ x: 0, offset: 0 });

  // Reset view when symbol or timeframe changes
  useEffect(() => { setOffset(0); setZoom(1); }, [symbol, tf]);

  // ── Resize observer ──
  useEffect(() => {
    const el = containerRef.current;
    if (!el) return;
    const ro = new ResizeObserver(e => {
      const { width, height } = e[0].contentRect;
      setDims({ w: Math.round(width), h: Math.round(height) });
    });
    ro.observe(el);
    return () => ro.disconnect();
  }, []);

  // ── Compute the visible candle slice ──
  const visibleCount = Math.round(Math.min(candles.length, Math.max(20, 80 / zoom)));
  const maxOffset    = Math.max(0, candles.length - visibleCount);
  const clampedOff   = Math.min(offset, maxOffset);

  // Candles visible: take from the right, shifted by offset
  const startIdx  = Math.max(0, candles.length - visibleCount - clampedOff);
  const endIdx    = Math.max(0, candles.length - clampedOff);
  const viewCandles = candles.slice(startIdx, endIdx);

  // Add live candle to view if we're at the right edge
  const showLive = clampedOff === 0 && livePrice && viewCandles.length > 0;
  const displayCandles = showLive ? [
    ...viewCandles,
    {
      time:  viewCandles[viewCandles.length - 1].time + TIMEFRAMES[tf]?.sec ?? 60,
      open:  viewCandles[viewCandles.length - 1].close,
      high:  Math.max(viewCandles[viewCandles.length - 1].close, livePrice),
      low:   Math.min(viewCandles[viewCandles.length - 1].close, livePrice),
      close: livePrice,
    },
  ] : viewCandles;

  // ── Mouse drag handlers (pan) ──
  const onMouseDown = useCallback(e => {
    isDragging.current = true;
    dragStart.current  = { x: e.clientX, offset: clampedOff };
  }, [clampedOff]);

  const onMouseMove = useCallback(e => {
    if (!isDragging.current) return;
    const canvas = canvasRef.current;
    if (!canvas) return;
    const dx       = e.clientX - dragStart.current.x;
    const chartW   = canvas.offsetWidth - PAD.l - PAD.r;
    const sp       = chartW / Math.max(1, visibleCount);
    const barsDx   = Math.round(-dx / sp);
    const newOff   = Math.max(0, Math.min(maxOffset, dragStart.current.offset + barsDx));
    setOffset(newOff);
  }, [visibleCount, maxOffset]);

  const onMouseUp = useCallback(() => { isDragging.current = false; }, []);

  // ── Scroll-to-zoom ──
  const onWheel = useCallback(e => {
    e.preventDefault();
    setZoom(prev => {
      const delta = e.deltaY > 0 ? 0.9 : 1.1;
      return Math.max(0.2, Math.min(5, prev * delta));
    });
  }, []);

  // ── Canvas draw ──
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas || !displayCandles.length) return;

    const dpr = window.devicePixelRatio || 1;
    const CW  = canvas.offsetWidth;
    const CH  = canvas.offsetHeight;

    if (canvas.width !== CW * dpr || canvas.height !== CH * dpr) {
      canvas.width  = CW * dpr;
      canvas.height = CH * dpr;
    }

    const ctx = canvas.getContext("2d");
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const chartW = CW - PAD.l - PAD.r;
    const chartH = CH - PAD.t - PAD.b;
    const all    = displayCandles;

    // Price range from visible candles
    let minP = Infinity, maxP = -Infinity;
    all.forEach(c => {
      if (c.low  < minP) minP = c.low;
      if (c.high > maxP) maxP = c.high;
    });
    const buf  = (maxP - minP) * 0.12 || 50;
    const lo   = minP - buf;
    const hi   = maxP + buf;
    const pRng = hi - lo;
    const toY  = p => PAD.t + ((hi - p) / pRng) * chartH;

    // Background
    ctx.fillStyle = "#0a0f1e";
    ctx.fillRect(0, 0, CW, CH);

    // Grid rows
    const gridCount = 6;
    ctx.lineWidth = 1;
    for (let i = 0; i <= gridCount; i++) {
      const y     = PAD.t + (i / gridCount) * chartH;
      const price = hi - (i / gridCount) * pRng;
      ctx.strokeStyle = "#0d1729";
      ctx.beginPath(); ctx.moveTo(PAD.l, y); ctx.lineTo(CW - PAD.r, y); ctx.stroke();
      ctx.fillStyle = "#3a4a5e"; ctx.font = "9px monospace"; ctx.textAlign = "left";
      ctx.fillText(price.toFixed(dec), CW - PAD.r + 5, y + 3);
    }

    // Candles
    const n  = all.length;
    const sp = chartW / n;
    const cw = Math.max(1, Math.min(sp * 0.75, 20));

    all.forEach((c, i) => {
      const x    = PAD.l + i * sp + sp / 2;
      const isUp = c.close >= c.open;
      const col  = isUp ? "#10b981" : "#ef4444";
      const wCol = isUp ? "#059669" : "#dc2626";

      // Wick
      ctx.strokeStyle = wCol; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(x, toY(c.high)); ctx.lineTo(x, toY(c.low)); ctx.stroke();

      // Body
      const by = toY(Math.max(c.open, c.close));
      const bh = Math.max(1, toY(Math.min(c.open, c.close)) - by);
      ctx.fillStyle = col;
      ctx.fillRect(Math.round(x - cw / 2), by, Math.max(1, cw), bh);

      // Hollow body for up candles when zoomed out
      if (isUp && cw > 3) {
        ctx.strokeStyle = col; ctx.lineWidth = 0.5;
        ctx.strokeRect(Math.round(x - cw / 2), by, Math.max(1, cw), bh);
      }
    });

    // Live price line + badge
    if (showLive && livePrice) {
      const ly = toY(livePrice);
      ctx.setLineDash([4, 3]); ctx.strokeStyle = "#38bdf8"; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(PAD.l, ly); ctx.lineTo(CW - PAD.r, ly); ctx.stroke();
      ctx.setLineDash([]);
      const bw = PAD.r - 4;
      ctx.fillStyle = "#38bdf8"; ctx.fillRect(CW - PAD.r, ly - 9, bw, 18);
      ctx.fillStyle = "#000"; ctx.font = "bold 9px monospace"; ctx.textAlign = "center";
      ctx.fillText(livePrice.toFixed(dec), CW - PAD.r + bw / 2, ly + 3.5);
    }

    // Symbol watermark
    ctx.font = "bold 20px monospace"; ctx.fillStyle = "rgba(255,255,255,0.02)";
    ctx.textAlign = "left"; ctx.globalAlpha = 1;
    ctx.fillText(symbol, PAD.l + 8, PAD.t + 28);

    // Grid vertical lines + time labels
    ctx.fillStyle = "#3a4a5e"; ctx.font = "8px monospace"; ctx.textAlign = "center";
    const labelEvery = Math.max(1, Math.ceil(n / 7));
    all.forEach((c, i) => {
      if (i % labelEvery !== 0) return;
      const x = PAD.l + i * sp + sp / 2;
      // Faint vertical grid
      ctx.strokeStyle = "#0e1a2a"; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(x, PAD.t); ctx.lineTo(x, CH - PAD.b); ctx.stroke();
      ctx.fillStyle = "#3a4a5e";
      ctx.fillText(formatCandleTime(c.time, tf), x, CH - PAD.b + 18);
    });

    // Panned indicator — show when not at live edge
    if (clampedOff > 0) {
      ctx.fillStyle = "rgba(56,189,248,0.6)";
      ctx.font = "9px monospace"; ctx.textAlign = "right";
      ctx.fillText(`← ${clampedOff} bars`, CW - PAD.r - 4, PAD.t + 14);
    }

  }, [displayCandles, livePrice, symbol, dec, tf, showLive, clampedOff]);

  return (
    <div
      ref={containerRef}
      style={{ position:"relative", width:"100%", height:"100%", cursor: isDragging.current ? "grabbing" : "crosshair" }}
      onMouseDown={onMouseDown}
      onMouseMove={onMouseMove}
      onMouseUp={onMouseUp}
      onMouseLeave={onMouseUp}
      onWheel={onWheel}
    >
      {/* Layer 1 — Canvas */}
      <canvas
        ref={canvasRef}
        style={{ position:"absolute", top:0, left:0, width:"100%", height:"100%", display:"block", userSelect:"none" }}
      />
      {/* Layer 2 — SVG trade overlays */}
      {dims.w > 0 && dims.h > 0 && (
        <TradeOverlays
          activeTrades={activeTrades}
          journalTrades={journalTrades}
          symbol={symbol}
          viewCandles={displayCandles}
          livePrice={showLive ? livePrice : null}
          dec={dec}
          width={dims.w}
          height={dims.h}
        />
      )}
    </div>
  );
}


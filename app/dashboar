                  })}
                </div>
              )}
            </div>
          )}

          {/* BOTS TAB */}
          {tab === "bots" && (
            <div style={{ flex: 1, overflow: "auto", padding: "12px" }}>
              <BotsPage
                session={session}
                bots={bots}
                strategies={allStrategies}
                activeTrades={activeTrades}
                onToggle={toggleBot}
                onDelete={deleteBot}
                onUpdateBot={updateBot}
              />
            </div>
          )}

          {/* STRATEGIES TAB */}
          {tab === "strategies" && (
            <div style={{ flex: 1, overflow: "auto", padding: "12px" }}>
              <StrategiesPage session={session} bots={bots} onLaunchBot={(strategy, stopExisting, opts, symbol) => {
              const existing = bots.find(b => b.strategyId === strategy.id);

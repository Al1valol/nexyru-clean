// ── useStrategies hook ────────────────────────────────────────

function useStrategies(username, btCandles, btSource) {
  const [strategies, setStrategies] = useState([]);

  // Seed on first load (no performance yet — will be computed below)
  useEffect(() => {
    const stored = loadAllStrategies();
    const hasSeeds = stored.some(s => s.isSeed);
    const all = hasSeeds ? stored : [...makeSeedStrategyDefs(), ...stored];
    if (!hasSeeds) saveAllStrategies(all);
    setStrategies(all);
  }, []);

  // Re-run backtest on seed strategies whenever real candles arrive
  useEffect(() => {
    if (!btCandles.length) return;
    setStrategies(prev => {
      let changed = false;
      const next = prev.map(s => {
        if (!s.isSeed) return s;
        const perf = backtestStrategy(s.rules, btCandles);
        changed = true;
        return { ...s, performance: perf, backtestSource: btSource };
      });
      if (changed) saveAllStrategies(next);
      return next;
    });
  }, [btCandles, btSource]);

  const saveStrategy = useCallback((strategy) => {
    setStrategies(prev => {
      const exists = prev.find(s => s.id === strategy.id);
      const next   = exists
        ? prev.map(s => s.id === strategy.id ? strategy : s)
        : [...prev, strategy];
      saveAllStrategies(next);
      return next;
    });
  }, []);

  const deleteStrategy = useCallback((id) => {
    setStrategies(prev => {
      const next = prev.filter(s => s.id !== id || s.isSeed);
      saveAllStrategies(next);
      return next;
    });
  }, []);

  const copyStrategy = useCallback((strategy, displayName) => {
    const copy = {
      ...strategy,
      id:        `strat_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
      name:      `${strategy.name} (copy)`,
      createdBy: username,
      createdAt: Date.now(),
      isPublic:  false,
      isSeed:    false,
    };
    setStrategies(prev => {
      const next = [...prev, copy];
      saveAllStrategies(next);
      return next;
    });
    return copy;
  }, [username]);

  // All strategies visible: public/seed ones + user's own
  const marketplace = useMemo(
    () => strategies.filter(s => s.isPublic || s.isSeed),
    [strategies]
  );

  const myStrategies = useMemo(
    () => strategies.filter(s => s.createdBy === username),
    [strategies, username]
  );

  return { strategies, marketplace, myStrategies, saveStrategy, deleteStrategy, copyStrategy };
}


        {/* Signal info */}
        <div style={{ padding: "10px 12px", borderRadius: 8, background: "#111827", marginBottom: 12 }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 6 }}>

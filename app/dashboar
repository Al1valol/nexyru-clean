            }}>
              <Bot size={13} style={{ color: isLong ? "#34d399" : "#f87171" }}/>
            </div>
            <div>
              <div style={{ fontSize: 11, fontWeight: 700, color: "#e2e8f0" }}>Trade Signal</div>
              <div style={{ fontSize: 9, color: "#475569" }}>{signal.botName}</div>
            </div>
          </div>
          <span style={{ fontSize: 10, fontFamily: "monospace", color: "#475569" }}>{timeLeft}s</span>

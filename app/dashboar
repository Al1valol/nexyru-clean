              border: `1px solid ${isLong ? "rgba(52,211,153,0.3)" : "rgba(239,68,68,0.3)"}`,
            }}>
              {isLong ? "▲ LONG" : "▼ SHORT"}
            </span>
            <span style={{ fontSize: 12, fontFamily: "monospace", fontWeight: 700, color: "#e2e8f0" }}>{signal.symbol}</span>
          </div>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 8 }}>
            {[
              { label: "Entry",  val: signal.entry.toFixed(2),    color: "#94a3b8" },
              { label: "SL",     val: signal.sl.toFixed(2),       color: "#f87171" },
              { label: "TP",     val: signal.tp.toFixed(2),       color: "#34d399" },
            ].map(({ label, val, color }) => (

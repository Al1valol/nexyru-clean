// ── Backtester ────────────────────────────────────────────────
// Runs strategy rules over simulated candle data and returns
// realistic (but clearly labelled) backtested performance stats.

function computeSimpleMA(closes, period) {
  const ma = [];
  for (let i = 0; i < closes.length; i++) {
    if (i < period - 1) { ma.push(null); continue; }
    const sum = closes.slice(i - period + 1, i + 1).reduce((a, b) => a + b, 0);
    ma.push(sum / period);
  }
  return ma;
}

function computeEMA(closes, period) {
  const ema = Array(closes.length).fill(null);
  const k = 2 / (period + 1);
  let started = false;
  let prev = 0;
  for (let i = 0; i < closes.length; i++) {
    if (i < period - 1) continue;
    if (!started) { prev = closes.slice(0, period).reduce((a, b) => a + b, 0) / period; ema[i] = prev; started = true; continue; }
    prev = closes[i] * k + prev * (1 - k);
    ema[i] = prev;
  }
  return ema;
}

function computeRSI(closes, period = 14) {
  const rsi = Array(closes.length).fill(null);
  if (closes.length < period + 1) return rsi;
  let gains = 0, losses = 0;
  for (let i = 1; i <= period; i++) {
    const diff = closes[i] - closes[i - 1];
    if (diff > 0) gains += diff; else losses -= diff;
  }
  let avgGain = gains / period;
  let avgLoss = losses / period;
  rsi[period] = 100 - (100 / (1 + (avgLoss === 0 ? Infinity : avgGain / avgLoss)));
  for (let i = period + 1; i < closes.length; i++) {
    const diff = closes[i] - closes[i - 1];
    const g = diff > 0 ? diff : 0;
    const l = diff < 0 ? -diff : 0;
    avgGain = (avgGain * (period - 1) + g) / period;
    avgLoss = (avgLoss * (period - 1) + l) / period;
    rsi[i] = 100 - (100 / (1 + (avgLoss === 0 ? Infinity : avgGain / avgLoss)));
  }
  return rsi;
}

// ── Realistic backtester ──────────────────────────────────────
// Includes: maker/taker fees, slippage, proper equity curve,
// Sharpe ratio, max drawdown, profit factor, expectancy,
// and walk-forward split (in-sample / out-of-sample).

const BACKTEST_FEE      = 0.001;  // 0.1% per side (Coinbase taker fee)
const BACKTEST_SLIPPAGE = 0.0005; // 0.05% slippage per fill
const MAX_HOLD_BARS     = 48;     // force-close after 48 bars

function computeBacktestTrades(rules, candles) {
  if (!candles.length || !rules.length) return [];

  const closes = candles.map(c => c.close);
  const highs  = candles.map(c => c.high);
  const lows   = candles.map(c => c.low);
  const rsi14  = computeRSI(closes, 14);
  const rsi7   = computeRSI(closes, 7);
  const ma20   = computeSimpleMA(closes, 20);
  const ma50   = computeSimpleMA(closes, 50);
  const ma100  = computeSimpleMA(closes, 100);
  const ma200  = computeSimpleMA(closes, 200);
  const ema9   = computeEMA(closes, 9);
  const ema12  = computeEMA(closes, 12);
  const ema21  = computeEMA(closes, 21);
  const ema26  = computeEMA(closes, 26);

  const FILTER_CONDITIONS = new Set([
    "price_above_ma","price_below_ma","price_above_ma50","price_below_ma50",
    "price_above_ema200","price_below_ema200"
  ]);

  const evalRule = (rule, i) => {
    const v = parseFloat(rule.value) || 14;
    const p = closes[i];
    switch (rule.condition) {
      case "price_breaks_high":  return p > Math.max(...highs.slice(Math.max(0, i - Math.round(v)), i));
      case "price_breaks_low":   return p < Math.min(...lows.slice(Math.max(0, i - Math.round(v)), i));
      case "rsi_below":          return rsi14[i] !== null && rsi14[i] < v;
      case "rsi_above":          return rsi14[i] !== null && rsi14[i] > v;
      case "rsi_cross_up":       return rsi14[i] !== null && rsi14[i-1] !== null && rsi14[i] >= v && rsi14[i-1] < v;
      case "rsi_cross_down":     return rsi14[i] !== null && rsi14[i-1] !== null && rsi14[i] <= v && rsi14[i-1] > v;
      case "rsi7_cross_up":      return rsi7[i]  !== null && rsi7[i-1]  !== null && rsi7[i]  >= v && rsi7[i-1]  < v;
      case "rsi7_cross_down":    return rsi7[i]  !== null && rsi7[i-1]  !== null && rsi7[i]  <= v && rsi7[i-1]  > v;
      case "ma_cross_up":        return ema9[i] !== null && ema21[i] !== null && ema9[i] > ema21[i] && ema9[i-1] !== null && ema9[i-1] <= ema21[i-1];
      case "ma_cross_down":      return ema9[i] !== null && ema21[i] !== null && ema9[i] < ema21[i] && ema9[i-1] !== null && ema9[i-1] >= ema21[i-1];
      case "price_above_ma":     return ma20[i]  !== null && p > ma20[i];
      case "price_below_ma":     return ma20[i]  !== null && p < ma20[i];
      case "price_above_ma50":   return ma50[i]  !== null && p > ma50[i];
      case "price_below_ma50":   return ma50[i]  !== null && p < ma50[i];
      case "price_above_ema200": return ma200[i] !== null && p > ma200[i];
      case "price_below_ema200": return ma200[i] !== null && p < ma200[i];
      case "macd_cross_up":  { const m=ema12[i]-ema26[i],pm=ema12[i-1]-ema26[i-1]; return ema12[i]!==null&&ema26[i]!==null&&m>0&&pm<=0; }
      case "macd_cross_down":{ const m=ema12[i]-ema26[i],pm=ema12[i-1]-ema26[i-1]; return ema12[i]!==null&&ema26[i]!==null&&m<0&&pm>=0; }
      case "ma20_cross_ma100_up":   return ma20[i]!==null&&ma100[i]!==null&&ma20[i]>ma100[i]&&ma20[i-1]!==null&&ma100[i-1]!==null&&ma20[i-1]<=ma100[i-1];
      case "ma20_cross_ma100_down": return ma20[i]!==null&&ma100[i]!==null&&ma20[i]<ma100[i]&&ma20[i-1]!==null&&ma100[i-1]!==null&&ma20[i-1]>=ma100[i-1];
      case "ma50_cross_ma200_up":   return ma50[i]!==null&&ma200[i]!==null&&ma50[i]>ma200[i]&&ma50[i-1]!==null&&ma200[i-1]!==null&&ma50[i-1]<=ma200[i-1];
      case "ma50_cross_ma200_down": return ma50[i]!==null&&ma200[i]!==null&&ma50[i]<ma200[i]&&ma50[i-1]!==null&&ma200[i-1]!==null&&ma50[i-1]>=ma200[i-1];
      case "price_breaks_52w_high": { const lb=Math.min(252,i); return p>Math.max(...highs.slice(i-lb,i)); }
      case "candle_bullish_engulf": return candles[i].close > candles[i].open && candles[i-1].close < candles[i-1].open && candles[i].close > candles[i-1].open;
      case "candle_bearish_engulf": return candles[i].close < candles[i].open && candles[i-1].close > candles[i-1].open && candles[i].close < candles[i-1].open;
      case "consecutive_green": { const cnt = Math.max(2, Math.round(v)); return i >= cnt && Array.from({length:cnt},(_,k)=>candles[i-k]).every(c=>c.close>c.open); }
      case "consecutive_red":   { const cnt = Math.max(2, Math.round(v)); return i >= cnt && Array.from({length:cnt},(_,k)=>candles[i-k]).every(c=>c.close<c.open); }
      case "pullback_in_uptrend": { const m = ma20[i]; return m !== null && p > m && Math.min(...closes.slice(Math.max(0,i-3),i)) <= m*1.005; }
      case "higher_low":  return i >= 2 && lows[i] > lows[i-1] && lows[i-1] > lows[i-2];
      case "volume_spike": return true;
      default: return false;
    }
  };

  const buyRules    = rules.filter(r => r.action === "buy");
  const sellRules   = rules.filter(r => r.action === "sell");
  const buyFilters  = buyRules.filter(r => FILTER_CONDITIONS.has(r.condition));
  const buyTriggers = buyRules.filter(r => !FILTER_CONDITIONS.has(r.condition));
  const sellTriggers = sellRules.filter(r => !FILTER_CONDITIONS.has(r.condition));
  const sellFilters  = sellRules.filter(r => FILTER_CONDITIONS.has(r.condition));

  // Entry: ALL filters true AND at least one trigger fires
  const buySignal  = i => buyRules.length > 0 &&
    buyFilters.every(r => evalRule(r, i)) &&
    (buyTriggers.length ? buyTriggers.some(r => evalRule(r, i)) : buyFilters.some(r => evalRule(r, i)));

  // Exit signal: only fires on TRIGGER conditions (not filters)
  // This prevents filter-only exits that fire immediately
  const sellExitSignal = i => sellTriggers.length > 0 &&
    sellFilters.every(r => evalRule(r, i)) &&
    sellTriggers.some(r => evalRule(r, i));

  const buyExitSignal = i => buyTriggers.length > 0 &&
    buyFilters.every(r => evalRule(r, i)) &&
    buyTriggers.some(r => evalRule(r, i));

  const trades  = [];
  let   position = null;

  for (let i = 20; i < candles.length - 1; i++) {
    if (!position) {
      if (buySignal(i)) {
        const fill = closes[i+1] * (1 + BACKTEST_SLIPPAGE);
        position = {
          type: "long", entryPrice: fill,
          entryCost: fill * BACKTEST_FEE,
          sl: fill * (1 - BOT_SL_PCT),
          tp: fill * (1 + BOT_TP_PCT),
          entryBar: i,
        };
      } else if (sellTriggers.length > 0 && sellExitSignal(i)) {
        const fill = closes[i+1] * (1 - BACKTEST_SLIPPAGE);
        position = {
          type: "short", entryPrice: fill,
          entryCost: fill * BACKTEST_FEE,
          sl: fill * (1 + BOT_SL_PCT),
          tp: fill * (1 - BOT_TP_PCT),
          entryBar: i,
        };
      }
    } else {
      const bar = candles[i];
      let exitPrice = null;

      if (position.type === "long") {
        if      (bar.low  <= position.sl)   exitPrice = position.sl;
        else if (bar.high >= position.tp)   exitPrice = position.tp;
        else if (sellExitSignal(i))         exitPrice = closes[i+1] * (1 - BACKTEST_SLIPPAGE);
        else if (i - position.entryBar >= MAX_HOLD_BARS) exitPrice = closes[i+1] * (1 - BACKTEST_SLIPPAGE);
      } else {
        if      (bar.high >= position.sl)   exitPrice = position.sl;
        else if (bar.low  <= position.tp)   exitPrice = position.tp;
        else if (buyExitSignal(i))          exitPrice = closes[i+1] * (1 + BACKTEST_SLIPPAGE);
        else if (i - position.entryBar >= MAX_HOLD_BARS) exitPrice = closes[i+1] * (1 + BACKTEST_SLIPPAGE);
      }

      if (exitPrice !== null) {
        const dir      = position.type === "long" ? 1 : -1;
        const grossPnl = dir * (exitPrice - position.entryPrice);
        const netPnl   = grossPnl - position.entryCost - exitPrice * BACKTEST_FEE;
        const pnlPct   = (netPnl / position.entryPrice) * 100;
        trades.push({ netPnl, grossPnl, pnlPct, entry: position.entryPrice, exit: exitPrice, type: position.type, bars: i - position.entryBar });
        position = null;
      }
    }
  }

  return trades;
}

function metricsFromTrades(trades) {
  if (!trades.length) return {
    totalTrades: 0, winRate: 0, pnl: 0, pnlPercent: 0,
    sharpe: 0, maxDrawdown: 0, profitFactor: 0,
    avgWin: 0, avgLoss: 0, expectancy: 0, avgHoldBars: 0,
  };

  const wins   = trades.filter(t => t.netPnl > 0);
  const losses = trades.filter(t => t.netPnl <= 0);

  const grossWin  = wins.reduce((s, t) => s + t.netPnl, 0);
  const grossLoss = Math.abs(losses.reduce((s, t) => s + t.netPnl, 0));
  const totalPnl  = +trades.reduce((s, t) => s + t.netPnl, 0).toFixed(2);
  const avgEntry  = trades.reduce((s, t) => s + t.entry, 0) / trades.length;
  const pnlPct    = avgEntry > 0 ? +((totalPnl / avgEntry) * 100).toFixed(2) : 0;
  const winRate   = +((wins.length / trades.length) * 100).toFixed(1);

  // Equity curve for Sharpe + drawdown
  let   equity    = 0;
  let   peak      = 0;
  let   maxDD     = 0;
  const returns   = [];

  trades.forEach(t => {
    const ret = t.pnlPct / 100;
    returns.push(ret);
    equity += t.netPnl;
    if (equity > peak) peak = equity;
    const dd = peak > 0 ? (peak - equity) / peak : 0;
    if (dd > maxDD) maxDD = dd;
  });

  // Sharpe (annualised, assuming 1h bars → 8760 periods/year)
  const avgR  = returns.reduce((s, r) => s + r, 0) / returns.length;
  const stdR  = Math.sqrt(returns.reduce((s, r) => s + (r - avgR) ** 2, 0) / returns.length);
  const sharpe = stdR > 0 ? +((avgR / stdR) * Math.sqrt(8760)).toFixed(2) : 0;

  const profitFactor = grossLoss > 0 ? +(grossWin / grossLoss).toFixed(2) : grossWin > 0 ? 99 : 0;
  const avgWin       = wins.length   ? +(grossWin  / wins.length).toFixed(2)   : 0;
  const avgLoss      = losses.length ? +(grossLoss / losses.length).toFixed(2) : 0;
  const expectancy   = +((winRate / 100) * avgWin - (1 - winRate / 100) * avgLoss).toFixed(2);
  const avgHoldBars  = Math.round(trades.reduce((s, t) => s + (t.bars ?? 0), 0) / trades.length);

  return {
    totalTrades: trades.length,
    winRate, pnl: totalPnl, pnlPercent: pnlPct,
    sharpe, maxDrawdown: +(maxDD * 100).toFixed(1),
    profitFactor, avgWin, avgLoss, expectancy, avgHoldBars,
  };
}

function backtestStrategy(rules, candles) {
  if (!candles.length || !rules.length) return metricsFromTrades([]);

  // ── Walk-forward split ──────────────────────────────────────
  // 70% in-sample (optimise), 30% out-of-sample (validate)
  // We run on the FULL dataset but tag which trades are OOS
  const splitIdx   = Math.floor(candles.length * 0.7);
  const isTrades   = computeBacktestTrades(rules, candles.slice(0, splitIdx));
  const oosTrades  = computeBacktestTrades(rules, candles.slice(splitIdx));
  const allTrades  = computeBacktestTrades(rules, candles);

  const isMetrics  = metricsFromTrades(isTrades);
  const oosMetrics = metricsFromTrades(oosTrades);
  const full       = metricsFromTrades(allTrades);

  return {
    ...full,
    // Walk-forward breakdown
    inSample:     { ...isMetrics,  label: "In-sample (70%)"  },
    outOfSample:  { ...oosMetrics, label: "Out-of-sample (30%)" },
    // Overfitting flag: if OOS win rate < IS win rate by >15pts, flag it
    overfitWarning: oosMetrics.totalTrades > 5 && (isMetrics.winRate - oosMetrics.winRate) > 15,
  };
}

// ── Seed marketplace strategies ───────────────────────────────

// ── useBacktestCandles — fetches real Binance 1h data for backtesting ──
// Uses 500 bars of BTCUSDT 1h from Binance REST.
// Falls back to sim if API is blocked (sandbox / no network).

function useBacktestCandles() {
  const [btCandles,   setBtCandles]   = useState([]);
  const [btSource,    setBtSource]    = useState("loading"); // "loading"|"real"|"sim"
  const [btSymbol,    setBtSymbol]    = useState("BTCUSD");
  const [btTf,        setBtTf]        = useState("1h");

  const load = useCallback(async (sym = "BTCUSD", tf = "1h") => {
    const cfg         = SYMBOLS_CFG[sym] ?? SYMBOLS_CFG.BTCUSD;
    const granularity = TF_TO_COINBASE[tf] ?? "ONE_HOUR";

    // Bar count strategy per timeframe:
    // 1m  → 3 pages × 300 = 900 bars = 15 hours   (scalping: need many signals)
    // 5m  → 3 pages × 300 = 900 bars = 3.1 days
    // 15m → 3 pages × 300 = 900 bars = 9.4 days
    // 1h  → 1 page  × 300 = 300 bars = 12.5 days
    // 4h  → 1 page  × 300 = 300 bars = 50 days
    // 1D  → 3 pages × 300 = 900 bars = 2.5 years
    const shortTFs = ["ONE_MINUTE", "FIVE_MINUTE", "FIFTEEN_MINUTE"];
    const pages    = (granularity === "ONE_DAY" || shortTFs.includes(granularity)) ? 3 : 1;
    const count    = pages * 300;

    setBtSource("loading");
    setBtSymbol(sym);
    setBtTf(tf);

    // For short TFs, only live crypto symbols have Coinbase data
    const liveSym = SYMBOLS_CFG[sym]?.coinbase ? sym : "BTCUSD";
    const liveCfg = SYMBOLS_CFG[liveSym];

    try {
      const raw    = await fetchCoinbaseCandles(liveCfg.coinbase, granularity, count);
      const parsed = raw.map(c => parseCoinbaseCandle(c, liveCfg.dec));
      setBtCandles(parsed);
      setBtSource("real");
      if (liveSym !== sym) setBtSymbol("BTCUSD"); // clarify what was fetched
    } catch {
      setBtCandles(genSimCandles(liveSym, tf, Math.min(count, 300)));
      setBtSource("sim");
    }
  }, []);

  // Load BTCUSD 1h on mount
  useEffect(() => { load(); }, []); // eslint-disable-line react-hooks/exhaustive-deps

  return { btCandles, btSource, btSymbol, btTf, loadBtCandles: load };
}


// ── Constants ─────────────────────────────────────────────────

const BOT_STORAGE_KEY   = "tradedesk_bots_v1";
const BOT_COOLDOWN_MS   = 30_000;  // 30s minimum between trades per bot
const BOT_TICK_MS       = 2_000;   // engine evaluates every 2 seconds
const BOT_SL_PCT        = 0.015;   // auto stop-loss: 1.5% from entry
const BOT_TP_PCT        = 0.030;   // auto take-profit: 3% from entry

// ── Bot storage ───────────────────────────────────────────────

function loadBots() {
  try { return JSON.parse(localStorage.getItem(BOT_STORAGE_KEY) || "[]"); }
  catch { return []; }
}
function saveBots(bots) {
  localStorage.setItem(BOT_STORAGE_KEY, JSON.stringify(bots));
}

// ── Signal evaluator (live, not backtester) ───────────────────
// Evaluates rules against a rolling price history window.
// Returns "buy" | "sell" | null

function evaluateSignal(rules, priceHistory) {
  if (!rules.length || priceHistory.length < 20) return null;

  const closes = priceHistory;
  const n      = closes.length;
  const last   = closes[n - 1];
  const prev   = closes[n - 2] ?? last;
  const prev2  = closes[n - 3] ?? prev;

  const rsi14  = computeRSI(closes, 14);
  const rsi7   = computeRSI(closes, 7);
  const ma20   = computeSimpleMA(closes, Math.min(20, n));
  const ma50   = computeSimpleMA(closes, Math.min(50, n));
  const ma100  = computeSimpleMA(closes, Math.min(100, n));
  const ma200  = computeSimpleMA(closes, Math.min(200, n));
  const ema9   = computeEMA(closes, Math.min(9,  n));
  const ema12  = computeEMA(closes, Math.min(12, n));
  const ema21  = computeEMA(closes, Math.min(21, n));
  const ema26  = computeEMA(closes, Math.min(26, n));

  const rsiNow    = rsi14[n-1]; const rsiPrev   = rsi14[n-2];
  const rsi7Now   = rsi7[n-1];  const rsi7Prev  = rsi7[n-2];
  const ema9Now   = ema9[n-1];  const ema9Prev  = ema9[n-2];
  const ema12Now  = ema12[n-1]; const ema12Prev = ema12[n-2];
  const ema21Now  = ema21[n-1]; const ema21Prev = ema21[n-2];
  const ema26Now  = ema26[n-1]; const ema26Prev = ema26[n-2];
  const ma20Now   = ma20[n-1];  const ma20Prev  = ma20[n-2];
  const ma50Now   = ma50[n-1];  const ma50Prev  = ma50[n-2];
  const ma100Now  = ma100[n-1]; const ma100Prev = ma100[n-2];
  const ma200Now  = ma200[n-1]; const ma200Prev = ma200[n-2];

  const evalRule = (rule) => {
    const v = parseFloat(rule.value) || 14;
    const lookback = Math.min(Math.round(v), n - 1);
    switch (rule.condition) {
      case "price_breaks_high":  return last > Math.max(...closes.slice(n - 1 - lookback, n - 1));
      case "price_breaks_low":   return last < Math.min(...closes.slice(n - 1 - lookback, n - 1));
      case "rsi_below":          return rsiNow  !== null && rsiNow < v;
      case "rsi_above":          return rsiNow  !== null && rsiNow > v;
      case "rsi_cross_up":       return rsiNow  !== null && rsiPrev  !== null && rsiNow  >= v && rsiPrev  < v;
      case "rsi_cross_down":     return rsiNow  !== null && rsiPrev  !== null && rsiNow  <= v && rsiPrev  > v;
      case "rsi7_cross_up":      return rsi7Now !== null && rsi7Prev !== null && rsi7Now >= v && rsi7Prev < v;
      case "rsi7_cross_down":    return rsi7Now !== null && rsi7Prev !== null && rsi7Now <= v && rsi7Prev > v;
      case "ma_cross_up":        return ema9Now !== null && ema21Now !== null && ema9Now > ema21Now && ema9Prev !== null && ema9Prev <= ema21Prev;
      case "ma_cross_down":      return ema9Now !== null && ema21Now !== null && ema9Now < ema21Now && ema9Prev !== null && ema9Prev >= ema21Prev;
      case "price_above_ma":     return ma20Now  !== null && last > ma20Now;
      case "price_below_ma":     return ma20Now  !== null && last < ma20Now;
      case "price_above_ma50":   return ma50Now  !== null && last > ma50Now;
      case "price_below_ma50":   return ma50Now  !== null && last < ma50Now;
      case "price_above_ema200": return ma200Now !== null && last > ma200Now;
      case "price_below_ema200": return ma200Now !== null && last < ma200Now;
      case "macd_cross_up":  { const m=ema12Now-ema26Now, pm=ema12Prev-ema26Prev; return ema12Now!==null&&ema26Now!==null&&m>0&&pm<=0; }
      case "macd_cross_down":{ const m=ema12Now-ema26Now, pm=ema12Prev-ema26Prev; return ema12Now!==null&&ema26Now!==null&&m<0&&pm>=0; }
      case "ma20_cross_ma100_up":   return ma20Now!==null&&ma100Now!==null&&ma20Now>ma100Now&&ma20Prev!==null&&ma100Prev!==null&&ma20Prev<=ma100Prev;
      case "ma20_cross_ma100_down": return ma20Now!==null&&ma100Now!==null&&ma20Now<ma100Now&&ma20Prev!==null&&ma100Prev!==null&&ma20Prev>=ma100Prev;
      case "ma50_cross_ma200_up":   return ma50Now!==null&&ma200Now!==null&&ma50Now>ma200Now&&ma50Prev!==null&&ma200Prev!==null&&ma50Prev<=ma200Prev;
      case "ma50_cross_ma200_down": return ma50Now!==null&&ma200Now!==null&&ma50Now<ma200Now&&ma50Prev!==null&&ma200Prev!==null&&ma50Prev>=ma200Prev;
      case "price_breaks_52w_high": { const lb=Math.min(252,n-1); return last>Math.max(...closes.slice(n-1-lb,n-1)); }
      case "candle_bullish_engulf": return last > prev && (last - prev) / Math.abs(prev) > 0.003;
      case "candle_bearish_engulf": return last < prev && (prev - last) / Math.abs(prev) > 0.003;
      case "consecutive_green": { const cnt=Math.max(2,Math.round(v)); return n>=cnt+1&&closes.slice(n-cnt).every((c,i,a)=>i===0||c>a[i-1]); }
      case "consecutive_red":   { const cnt=Math.max(2,Math.round(v)); return n>=cnt+1&&closes.slice(n-cnt).every((c,i,a)=>i===0||c<a[i-1]); }
      case "pullback_in_uptrend": return ma20Now !== null && last > ma20Now && Math.min(prev, prev2) <= ma20Now * 1.005;
      case "higher_low": return n >= 3 && closes[n-1] > closes[n-2] && closes[n-2] > closes[n-3];
      case "volume_spike": return true;
      default: return false;
    }
  };

  const FILTER_CONDITIONS = new Set(["price_above_ma","price_below_ma","price_above_ma50","price_below_ma50","price_above_ema200","price_below_ema200"]);

  const buyRules     = rules.filter(r => r.action === "buy");
  const sellRules    = rules.filter(r => r.action === "sell");
  const buyFilters   = buyRules.filter(r =>  FILTER_CONDITIONS.has(r.condition));
  const buyTriggers  = buyRules.filter(r => !FILTER_CONDITIONS.has(r.condition));
  const sellFilters  = sellRules.filter(r =>  FILTER_CONDITIONS.has(r.condition));
  const sellTriggers = sellRules.filter(r => !FILTER_CONDITIONS.has(r.condition));

  const buyFires  = buyRules.length > 0 &&
    buyFilters.every(r => evalRule(r)) &&
    (buyTriggers.length ? buyTriggers.some(r => evalRule(r)) : buyFilters.some(r => evalRule(r)));

  // Exit signals only fire on TRIGGER conditions — prevents immediate re-exit on filter conditions
  const sellFires = sellTriggers.length > 0 &&
    sellFilters.every(r => evalRule(r)) &&
    sellTriggers.some(r => evalRule(r));

  if (buyFires)  return "buy";
  if (sellFires) return "sell";
  return null;
}

// ── useBots hook — manages bot CRUD ──────────────────────────

function useBots(username) {
  const [bots, setBots] = useState([]);

  useEffect(() => {
    // Load only this user's bots
    const all = loadBots().filter(b => b.owner === username);
    setBots(all);
  }, [username]);

  const persist = useCallback((next) => {
    // Merge with other users' bots before saving
    const others = loadBots().filter(b => b.owner !== username);
    saveBots([...others, ...next]);
  }, [username]);

  const createBot = useCallback((strategyId, strategyName, symbol, opts = {}) => {
    const bot = {
      id:             `bot_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
      owner:          username,
      strategyId,
      strategyName,
      symbol:         symbol ?? "BTCUSD",
      // ── Mode ──────────────────────────────────────────────────
      mode:           opts.mode ?? "full",      // "semi" | "full"
      // ── Risk rules ────────────────────────────────────────────
      riskPct:        opts.riskPct        ?? 1,   // % of account per trade
      maxDailyLoss:   opts.maxDailyLoss   ?? 3,   // % daily loss circuit-breaker
      maxDailyTrades: opts.maxDailyTrades ?? 5,   // max trades today
      cooldownMs:     opts.cooldownMs     ?? BOT_COOLDOWN_MS,
      // ── Runtime state ─────────────────────────────────────────
      isActive:       false,
      createdAt:      Date.now(),
      lastRun:        0,
      lastSignal:     null,
      tradesExecuted: 0,
      todayTrades:    0,
      todayPnl:       0,
      todayDate:      new Date().toDateString(), // reset daily
      totalPnl:       0,
      peakPnl:        0,
      maxDrawdown:    0,
      tradeHistory:   [],
      log:            [],
      // ── Semi-auto pending signal ───────────────────────────────
      pendingSignal:  null, // { direction, entry, sl, tp, timestamp }
    };
    setBots(prev => { const next = [...prev, bot]; persist(next); return next; });
    return bot;
  }, [username, persist]);

  const updateBot = useCallback((id, patch) => {
    setBots(prev => {
      const next = prev.map(b => b.id === id ? { ...b, ...patch } : b);
      persist(next);
      return next;
    });
  }, [persist]);

  const deleteBot = useCallback((id) => {
    setBots(prev => { const next = prev.filter(b => b.id !== id); persist(next); return next; });
  }, [persist]);

  const toggleBot = useCallback((id) => {
    setBots(prev => {
      const next = prev.map(b => b.id === id ? { ...b, isActive: !b.isActive } : b);
      persist(next);
      return next;
    });
  }, [persist]);

  return { bots, createBot, updateBot, deleteBot, toggleBot };
}

// ── useBotEngine hook — the main execution loop ────────────────
//
// Runs every BOT_TICK_MS (2s).
// For each active bot:
//   1. Build a price history window from candles + current price
//   2. Evaluate strategy rules → signal
//   3. If "buy"/"sell" and no open trade → open trade via openTrade()
//   4. If opposite signal and trade open → close it via closeTrade()
//   5. Enforce cooldown so it can't spam trades

function useBotEngine({ bots, updateBot, strategies, prices, candles, openTrade, closeTrade, activeTrades, onPendingSignal }) {
  const botsRef          = useRef(bots);
  const strategiesRef    = useRef(strategies);
  const pricesRef        = useRef(prices);
  const candlesRef       = useRef(candles);
  const activeTradesRef  = useRef(activeTrades);

  botsRef.current         = bots;
  strategiesRef.current   = strategies;
  pricesRef.current       = prices;
  candlesRef.current      = candles;
  activeTradesRef.current = activeTrades;

  // ── Helper: reset daily counters if new day ──────────────────
  const checkDayReset = (bot, now) => {
    const today = new Date(now).toDateString();
    if (bot.todayDate !== today) {
      return { todayTrades: 0, todayPnl: 0, todayDate: today };
    }
    return null;
  };

  // ── Helper: actually execute a trade ─────────────────────────
  const executeTrade = (bot, signal, livePx, symCfg, strategy, now) => {
    const tradeType = signal === "buy" ? "long" : "short";
    const entry     = livePx;
    const slPct     = BOT_SL_PCT;
    const tpPct     = BOT_TP_PCT;
    const sl = tradeType === "long"
      ? +(entry * (1 - slPct)).toFixed(symCfg.dec)
      : +(entry * (1 + slPct)).toFixed(symCfg.dec);
    const tp = tradeType === "long"
      ? +(entry * (1 + tpPct)).toFixed(symCfg.dec)
      : +(entry * (1 - tpPct)).toFixed(symCfg.dec);

    openTrade({
      symbol: bot.symbol, type: tradeType,
      entryPrice: entry, stopLoss: sl, takeProfit: tp,
      size: 1, botId: bot.id, strategy: strategy.name,
    });

    const log = `${new Date(now).toLocaleTimeString()} — ${signal.toUpperCase()} → opened ${tradeType} @ ${entry.toFixed(symCfg.dec)}`;
    updateBot(bot.id, {
      lastRun: now, lastSignal: signal, pendingSignal: null,
      tradesExecuted: bot.tradesExecuted + 1,
      todayTrades: (bot.todayTrades ?? 0) + 1,
      log: [log, ...(bot.log ?? [])].slice(0, 20),
    });
  };

  useEffect(() => {
    const tick = () => {
      const now        = Date.now();
      const activeBots = botsRef.current.filter(b => b.isActive);
      if (!activeBots.length) return;

      activeBots.forEach(bot => {
        const cooldown = bot.cooldownMs ?? BOT_COOLDOWN_MS;

        // ── Reset daily stats if new day ───────────────────────
        const dayReset = checkDayReset(bot, now);
        if (dayReset) updateBot(bot.id, dayReset);

        // ── Risk circuit-breakers (full-auto only) ─────────────
        if (bot.mode !== "semi") {
          const todayTrades = dayReset ? 0 : (bot.todayTrades ?? 0);
          const todayPnl    = dayReset ? 0 : (bot.todayPnl ?? 0);
          // Max daily trades hit
          if (todayTrades >= (bot.maxDailyTrades ?? 5)) return;
          // Max daily loss hit (negative pnl exceeds threshold)
          if (todayPnl < 0 && Math.abs(todayPnl) >= (bot.maxDailyLoss ?? 3)) return;
        }

        // ── Cooldown check ─────────────────────────────────────
        if (now - bot.lastRun < cooldown) return;

        // ── Strategy lookup ────────────────────────────────────
        const strategy = strategiesRef.current.find(s => s.id === bot.strategyId);
        if (!strategy?.rules?.length) return;

        // ── Price history ──────────────────────────────────────
        const sym    = bot.symbol;
        const symCfg = SYMBOLS_CFG[sym] ?? SYMBOLS_CFG.BTCUSD;
        const livePx = pricesRef.current[sym] ?? symCfg.simBase;
        const history = [...candlesRef.current.slice(-60).map(c => c.close), livePx];
        if (history.length < 20) return;

        // ── Signal evaluation ──────────────────────────────────
        const signal = evaluateSignal(strategy.rules, history);
        const existingTrade = activeTradesRef.current.find(t => t.botId === bot.id);

        if (!existingTrade) {
          if (!signal) return;

          if (bot.mode === "semi") {
            // ── SEMI-AUTO: queue pending signal ───────────────
            // Don't queue if already have one pending
            if (bot.pendingSignal) return;
            const direction = signal === "buy" ? "long" : "short";
            const entry = livePx;
            const sl = direction === "long" ? +(entry*(1-BOT_SL_PCT)).toFixed(symCfg.dec) : +(entry*(1+BOT_SL_PCT)).toFixed(symCfg.dec);
            const tp = direction === "long" ? +(entry*(1+BOT_TP_PCT)).toFixed(symCfg.dec) : +(entry*(1-BOT_TP_PCT)).toFixed(symCfg.dec);
            const pending = { direction, entry, sl, tp, timestamp: now, botId: bot.id, botName: bot.strategyName, symbol: sym };
            updateBot(bot.id, { pendingSignal: pending, lastRun: now });
            onPendingSignal?.(pending);
          } else {
            // ── FULL-AUTO: trade immediately ──────────────────
            executeTrade(bot, signal, livePx, symCfg, strategy, now);
          }
        } else {
          // ── Exit logic: same for both modes ───────────────────
          const shouldClose =
            (existingTrade.type === "long"  && signal === "sell") ||
            (existingTrade.type === "short" && signal === "buy");

          if (shouldClose) {
            closeTrade(existingTrade.id);
            const tradePnl   = existingTrade.pnl ?? 0;
            const newTotal   = (bot.totalPnl ?? 0) + tradePnl;
            const newPeak    = Math.max(bot.peakPnl ?? 0, newTotal);
            const dd         = newPeak > 0 ? ((newPeak - newTotal) / newPeak) * 100 : 0;
            const log = `${new Date(now).toLocaleTimeString()} — closed ${existingTrade.type} @ ${livePx.toFixed(symCfg.dec)} · ${tradePnl >= 0 ? "+" : ""}${tradePnl.toFixed(2)}`;
            updateBot(bot.id, {
              lastRun: now, lastSignal: signal, pendingSignal: null,
              totalPnl: +newTotal.toFixed(4),
              peakPnl: +newPeak.toFixed(4),
              maxDrawdown: +Math.max(bot.maxDrawdown ?? 0, dd).toFixed(1),
              todayPnl: +(((bot.todayPnl ?? 0) + tradePnl)).toFixed(4),
              tradeHistory: [{ pnl: tradePnl, pnlPct: existingTrade.pnlPercent ?? 0, type: existingTrade.type, closedAt: now }, ...(bot.tradeHistory ?? [])].slice(0, 50),
              log: [log, ...(bot.log ?? [])].slice(0, 20),
            });
          }
        }
      });
    };

    const id = setInterval(tick, BOT_TICK_MS);
    return () => clearInterval(id);
  }, []); // eslint-disable-line react-hooks/exhaustive-deps
}


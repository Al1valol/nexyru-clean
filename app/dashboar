const PAD = { t: 20, b: 36, l: 8, r: 76 };

// ─────────────────────────────────────────────────────────────
//  TRADE OVERLAYS  — SVG layer with SL/TP lines + hover tooltips
// ─────────────────────────────────────────────────────────────
function TradeOverlays({
  activeTrades, journalTrades, symbol, viewCandles,
  livePrice, dec, width, height,
}) {
  const [hovered, setHovered] = useState(null);

  // Compute price range from the visible candle slice
  const scale = useMemo(() => {
    const all = [...viewCandles];
    if (!all.length) return null;
    if (livePrice && all.length) {
      const last = all[all.length - 1];
      all[all.length - 1] = {
        ...last,
        high:  Math.max(last.high, livePrice),
        low:   Math.min(last.low,  livePrice),
        close: livePrice,
      };
    }
    let minP = Infinity, maxP = -Infinity;
    all.forEach(c => {
      if (c.low  < minP) minP = c.low;
      if (c.high > maxP) maxP = c.high;
    });
    const buf = (maxP - minP) * 0.12 || 50;
    return { lo: minP - buf, hi: maxP + buf, all };
  }, [viewCandles, livePrice]);

  if (!scale || !width || !height) return null;

  const { lo, hi, all } = scale;
  const pRng  = hi - lo;
  const chartW = width  - PAD.l - PAD.r;
  const chartH = height - PAD.t - PAD.b;
  const toY    = p => PAD.t + ((hi - p) / pRng) * chartH;
  const inRange = p => p != null && p >= lo && p <= hi;

  const n  = all.length;
  const sp = chartW / n;

  const candleX = timeMs => {
    const timeSec = Math.floor(timeMs / 1000);
    let best = 0, bestDist = Infinity;
    all.forEach((c, i) => {
      const d = Math.abs(c.time - timeSec);
      if (d < bestDist) { bestDist = d; best = i; }
    });
    return PAD.l + best * sp + sp / 2;
  };

  const myActive = activeTrades.filter(t => t.symbol === symbol);
  const myClosed = journalTrades.filter(t => t.symbol === symbol && t.strategy === "Live Trade");

  // ── Inline tooltip ──
  const OvTooltip = ({ x, y, lines }) => {
    const W = 140, H = lines.length * 16 + 14;
    const tx = Math.min(x + 12, width - W - 4);
    const ty = Math.max(PAD.t, Math.min(y - H / 2, height - PAD.b - H));
    return (
      <g pointerEvents="none">
        <rect x={tx} y={ty} width={W} height={H} rx={6}
          fill="#0d1120" stroke="rgba(99,102,241,0.5)" strokeWidth={1}/>
        {lines.map((l, i) => (
          <text key={i} x={tx + 9} y={ty + 14 + i * 16}
            fill={l.color || "#cbd5e1"} fontSize={10} fontFamily="monospace">{l.text}</text>
        ))}
      </g>
    );
  };

  // ── Single horizontal trade line ──
  const TradeLine = ({ trade, price, color, glow, kind, label }) => {
    if (!inRange(price)) return null;
    const y    = toY(price);
    const x1   = PAD.l;
    const x2   = width - PAD.r;
    const id   = `${trade.id}_${kind}`;
    const isHov = hovered?.id === id;
    const lW   = label === "Entry" ? 42 : 26;

    return (
      <g key={id}
        onMouseEnter={() => setHovered({ id, kind, price, pnl: trade.pnl, type: trade.type })}
        onMouseLeave={() => setHovered(null)}
        style={{ cursor: "crosshair" }}
      >
        {/* Glow */}
        <line x1={x1} y1={y} x2={x2} y2={y}
          stroke={glow} strokeWidth={isHov ? 8 : 4} strokeOpacity={isHov ? 0.2 : 0.08}/>
        {/* Line */}
        <line x1={x1} y1={y} x2={x2} y2={y}
          stroke={color} strokeWidth={isHov ? 1.5 : 1} strokeOpacity={isHov ? 1 : 0.9}/>
        {/* Wide invisible hit area */}
        <line x1={x1} y1={y} x2={x2} y2={y} stroke="transparent" strokeWidth={14}/>
        {/* Left label pill */}
        <rect x={x1} y={y - 9} width={lW} height={18} rx={3} fill={color} opacity={isHov ? 1 : 0.88}/>
        <text x={x1 + lW / 2} y={y + 4} fill="#000" fontSize={9}
          fontFamily="monospace" fontWeight="700" textAnchor="middle">{label}</text>
        {/* Right price badge */}
        <rect x={x2} y={y - 9} width={PAD.r - 4} height={18} rx={3} fill={color} opacity={0.9}/>
        <text x={x2 + (PAD.r - 4) / 2} y={y + 4} fill="#000" fontSize={9}
          fontFamily="monospace" fontWeight="700" textAnchor="middle">{price.toFixed(dec)}</text>
        {/* Tooltip */}
        {isHov && (
          <OvTooltip x={x1 + lW + 6} y={y} lines={[
            { text: `${trade.symbol} ${trade.type.toUpperCase()}`, color: trade.type === "long" ? "#34d399" : "#f87171" },
            { text: `${kind}: ${price.toFixed(dec)}`, color },
            ...(trade.pnl != null ? [{ text: `PnL: ${trade.pnl >= 0 ? "+" : ""}${trade.pnl.toFixed(2)}`, color: trade.pnl >= 0 ? "#34d399" : "#f87171" }] : []),
          ]}/>
        )}
      </g>
    );
  };

  // ── Closed trade markers ──
  const ClosedMarker = ({ trade }) => {
    const isWin = trade.pnl >= 0;
    const clr   = isWin ? "#10b981" : "#ef4444";
    const entryY = inRange(trade.entryPrice) ? toY(trade.entryPrice) : null;
    const exitY  = inRange(trade.exitPrice)  ? toY(trade.exitPrice)  : null;
    const entryX = candleX(trade.date - 3_600_000);
    const exitX  = candleX(trade.date);
    return (
      <g opacity={0.65}>
        {entryY != null && exitY != null && (
          <line x1={entryX} y1={entryY} x2={exitX} y2={exitY}
            stroke={clr} strokeWidth={1} strokeOpacity={0.3} strokeDasharray="4 3"/>
        )}
        {entryY != null && (
          <>
            <circle cx={entryX} cy={entryY} r={5} fill={clr} opacity={0.1}/>
            <circle cx={entryX} cy={entryY} r={3} fill={clr} opacity={0.8}/>
          </>
        )}
        {exitY != null && (
          <>
            <circle cx={exitX} cy={exitY} r={5} fill={clr} opacity={0.15}/>
            <line x1={exitX-3} y1={exitY-3} x2={exitX+3} y2={exitY+3} stroke={clr} strokeWidth={1.5}/>
            <line x1={exitX+3} y1={exitY-3} x2={exitX-3} y2={exitY+3} stroke={clr} strokeWidth={1.5}/>
          </>
        )}
      </g>
    );
  };

  return (
    <svg width={width} height={height}
      style={{ position:"absolute", top:0, left:0, pointerEvents:"none", overflow:"visible" }}>
      {/* Closed markers */}
      <g pointerEvents="none">
        {myClosed.slice(-20).map(t => <ClosedMarker key={t.id} trade={t}/>)}
      </g>
      {/* Active trade lines — fully interactive */}
      <g pointerEvents="all">
        {myActive.map(trade => (
          <g key={trade.id}>
            {/* Zone: entry → TP */}
            {inRange(trade.entryPrice) && inRange(trade.takeProfit) && (
              <rect x={PAD.l} width={chartW}
                y={Math.min(toY(trade.entryPrice), toY(trade.takeProfit))}
                height={Math.abs(toY(trade.entryPrice) - toY(trade.takeProfit))}
                fill={trade.type === "long" ? "rgba(16,185,129,0.05)" : "rgba(239,68,68,0.05)"}
                pointerEvents="none"
              />
            )}
            {/* Zone: entry → SL */}
            {inRange(trade.entryPrice) && inRange(trade.stopLoss) && (
              <rect x={PAD.l} width={chartW}
                y={Math.min(toY(trade.entryPrice), toY(trade.stopLoss))}
                height={Math.abs(toY(trade.entryPrice) - toY(trade.stopLoss))}
                fill="rgba(239,68,68,0.03)"
                pointerEvents="none"
              />
            )}
            <TradeLine trade={trade} price={trade.stopLoss}   color="#ef4444" glow="#ef4444" kind="SL"    label="SL"/>
            <TradeLine trade={trade} price={trade.takeProfit} color="#10b981" glow="#10b981" kind="TP"    label="TP"/>
            <TradeLine trade={trade} price={trade.entryPrice} color="#e2e8f0" glow="#6366f1" kind="Entry" label="Entry"/>
          </g>
        ))}
      </g>
    </svg>
  );
}


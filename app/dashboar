export default function App() {
  const { session, hydrated, login, register, logout } = useAuth();

  if (!hydrated) {
    // Avoid SSR mismatch — show nothing until localStorage is read
    return (
      <div style={{ minHeight: "100dvh", background: "#0b0e17", display: "flex", alignItems: "center", justifyContent: "center" }}>
        <div style={{ width: 32, height: 32, border: "3px solid #1a2035", borderTopColor: "#38bdf8", borderRadius: "50%", animation: "spin 0.7s linear infinite" }}/>
        <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
      </div>
    );
  }

  if (!session) {
    return <AuthScreen onLogin={login} onRegister={register}/>;
  }

  return <TradingDashboard session={session} onLogout={logout}/>;
}


// ═══════════════════════════════════════════════════════════════
//  MAIN DASHBOARD  (receives session from auth gate)
// ═══════════════════════════════════════════════════════════════

function TradingDashboard({ session, onLogout }) {

  // ── Live prices ───────────────────────────────────────────────
  const [prices, setPrices] = useState(() =>
    Object.fromEntries(SYM_LIST.map(s => [s, SYMBOLS_CFG[s].simBase]))
  );
  const [dataSource, setDataSource] = useState("connecting");
  const [loading,    setLoading]    = useState(false);
  const [forceSim,   setForceSim]   = useState(false);

  // ── Selected symbol, timeframe & candles ─────────────────────
  const [sym,     setSym]     = useState("BTCUSD");
  const [tf,      setTf]      = useState("1m");
  const [candles, setCandles] = useState([]);

  const cfg       = SYMBOLS_CFG[sym] ?? SYMBOLS_CFG.BTCUSD;
  const isLiveSym = LIVE_SYMS.has(sym);

  // ── Connectivity test — check if Coinbase API is reachable ───
  const [apiReachable, setApiReachable] = useState(null);

  useEffect(() => {
    fetch(`/api/coinbase?params=${encodeURIComponent("product_id=BTC-USD")}`)
      .then(r => { setApiReachable(r.ok); if (!r.ok) setForceSim(true); })
      .catch(() => { setApiReachable(false); setForceSim(true); });
  }, []); // eslint-disable-line react-hooks/exhaustive-deps

  // ── Fetch historical candles (REST) ──────────────────────────
  useEffect(() => {
    let cancelled = false;
    setLoading(true);
    setCandles([]);

    const granularity = TF_TO_COINBASE[tf];
    const useSim = !isLiveSym || !granularity || forceSim || apiReachable === false;

    if (useSim) {
      const tfCfg = TIMEFRAMES[tf] ?? TIMEFRAMES["1m"];
      setCandles(genSimCandles(sym, tf, tfCfg.count));
      setLoading(false);
      setDataSource("sim");
      return;
    }

    fetchCoinbaseCandles(cfg.coinbase, granularity, Math.min(TIMEFRAMES[tf]?.count ?? 200, 300))
      .then(raw => {
        if (cancelled) return;
        const parsed = raw.map(c => parseCoinbaseCandle(c, cfg.dec));
        setCandles(parsed);
        if (parsed.length)
          setPrices(prev => ({ ...prev, [sym]: parsed[parsed.length - 1].close }));
        setLoading(false);
        setDataSource("live");
        setApiReachable(true);
      })
      .catch(() => {
        if (cancelled) return;
        setApiReachable(false);
        const tfCfg = TIMEFRAMES[tf] ?? TIMEFRAMES["1m"];
        setCandles(genSimCandles(sym, tf, tfCfg.count));
        setLoading(false);
        setDataSource("sim");
        setForceSim(true);
      });

    return () => { cancelled = true; };
  }, [sym, tf, forceSim, apiReachable]); // eslint-disable-line react-hooks/exhaustive-deps

  // ── Simulated ticker (always runs — drives PnL for all symbols) ─
  useEffect(() => {
    const id = setInterval(() => {
      setPrices(prev => {
        const next = { ...prev };
        SYM_LIST.forEach(s => {
          if (forceSim || !LIVE_SYMS.has(s))
            next[s] = nextTick(prev[s], SYMBOLS_CFG[s]);
        });
        return next;
      });
    }, 1200);
    return () => clearInterval(id);
  }, [forceSim]);

  // ── REST polling — live price + forming candle ────────────────
  useEffect(() => {
    const useSim = !isLiveSym || forceSim || apiReachable === false;
    if (useSim) { setDataSource("sim"); return; }

    let cancelled    = false;
    let failStreak   = 0; // only kill live mode after 5 consecutive failures

    const poll = async () => {
      try {
        const granularity = TF_TO_COINBASE[tf] ?? "ONE_MINUTE";
        const granSecs = {
          ONE_MINUTE: 60, FIVE_MINUTE: 300, FIFTEEN_MINUTE: 900,
          ONE_HOUR: 3600, SIX_HOUR: 21600, ONE_DAY: 86400,
        }[granularity] ?? 60;

        // Fetch just the last 2 candles to get the forming bar + current price
        const end   = Math.floor(Date.now() / 1000);
        const start = end - 2 * granSecs;
        const params = `product_id=${cfg.coinbase}&start=${start}&end=${end}&granularity=${granularity}`;
        const res = await fetch(`/api/coinbase?params=${encodeURIComponent(params)}`);

        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (!data.candles?.length) throw new Error("no candles");
        if (cancelled) return;

        // candles are newest-first from Coinbase
        const latestCandle = data.candles[0];
        const livePrice    = +parseFloat(latestCandle.close).toFixed(cfg.dec);

        failStreak = 0; // reset on success
        setPrices(prev => ({ ...prev, [sym]: livePrice }));
        setDataSource("live");

        // Update forming candle in chart
        const forming = parseCoinbaseCandle(latestCandle, cfg.dec);
        setCandles(prev => {
          if (!prev.length) return prev;
          const last = prev[prev.length - 1];
          if (forming.time === last.time) {
            if (last.close === forming.close && last.high === forming.high && last.low === forming.low)
              return prev;
            return [...prev.slice(0, -1), forming];
          }
          // New bar
        return [...prev.slice(-499), forming];
        });

      } catch {
        if (cancelled) return;
        failStreak++;
        // Only fall back to sim after 5 consecutive failures (network blip tolerance)
        if (failStreak >= 5) {
          setDataSource("sim");
          setApiReachable(false);
          setForceSim(true);
        }
      }
    };

    poll();
    const id = setInterval(poll, 3000);
    return () => { cancelled = true; clearInterval(id); };
  }, [sym, tf, forceSim, apiReachable]); // eslint-disable-line react-hooks/exhaustive-deps

  // ── Coinbase WebSocket — real-time price (~100ms) ─────────────
  // Connects directly from browser (no CORS on wss://)
  // Runs alongside the poll — WS gives fast price, poll keeps candles fresh
  const wsRef = useRef(null);
  useEffect(() => {
    if (!isLiveSym || forceSim || apiReachable === false) return;

    const ws = new WebSocket("wss://advanced-trade-ws.coinbase.com");
    wsRef.current = ws;
    let opened = false;

    ws.onopen = () => {
      opened = true;
      ws.send(JSON.stringify({
        type:        "subscribe",
        product_ids: [cfg.coinbase],
        channel:     "ticker",
      }));
    };

    ws.onmessage = (e) => {
      try {
        const msg = JSON.parse(e.data);
        if (msg.channel !== "ticker") return;
        const event = msg.events?.[0];
        const ticker = event?.tickers?.[0];
        if (!ticker?.price) return;
        const price = +parseFloat(ticker.price).toFixed(cfg.dec);
        setPrices(prev => ({ ...prev, [sym]: price }));
        setDataSource("live");
      } catch {}
    };

    ws.onerror = () => {};  // poll is fallback — don't kill live mode
    ws.onclose = () => {};

    return () => {
      if (opened && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({
          type:        "unsubscribe",
          product_ids: [cfg.coinbase],
          channel:     "ticker",
        }));
      }
      ws.close();
      wsRef.current = null;
    };
  }, [sym, forceSim, apiReachable]); // eslint-disable-line react-hooks/exhaustive-deps

  const curPrice  = prices[sym] ?? cfg.simBase;
  const lastClose = candles[candles.length - 1]?.close ?? cfg.simBase;
  const priceUp   = curPrice >= lastClose;
  const pct       = lastClose ? ((curPrice - lastClose) / lastClose * 100).toFixed(3) : "0.000";

  const addToJournal = useCallback(closed => {
    const { pnl, pnlPercent } = calcPnl(closed.type, closed.entryPrice, closed.exitPrice, closed.size);
    setJournalTrades(prev => [...prev, {
      id: `j_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
      symbol: closed.symbol, type: closed.type,
      entryPrice: closed.entryPrice, exitPrice: closed.exitPrice,
      stopLoss: closed.stopLoss, takeProfit: closed.takeProfit,
      date: Date.now(),
      strategy: closed.strategy ?? (closed.botId ? "Bot Trade" : "Live Trade"),
      size: closed.size,
      tags: closed.botId ? ["Bot"] : [], notes: "", confidence: 3,
      pnl, pnlPercent,
    }]);
  }, []);

  // Update PnL + check SL/TP on every price tick
  useEffect(() => {
    setActiveTrades(prev => {
      if (!prev.length) return prev;
      const toClose = [];
      const updated = prev.map(t => {
        const cur = prices[t.symbol] ?? t.currentPrice;
        const { pnl, pnlPercent } = calcPnl(t.type, t.entryPrice, cur, t.size);
        const slHit = t.stopLoss   != null && (t.type === "long" ? cur <= t.stopLoss   : cur >= t.stopLoss);
        const tpHit = t.takeProfit != null && (t.type === "long" ? cur >= t.takeProfit : cur <= t.takeProfit);
        if (slHit || tpHit) toClose.push({ ...t, currentPrice: cur, pnl, pnlPercent });
        return { ...t, currentPrice: cur, pnl, pnlPercent };
      });
      if (toClose.length) {
        const ids = new Set(toClose.map(t => t.id));
        setTimeout(() => toClose.forEach(t => addToJournal({ ...t, exitPrice: t.currentPrice })), 0);
        return updated.filter(t => !ids.has(t.id));
      }
      return updated;
    });
  }, [prices, addToJournal]);

  const openTrade = useCallback(({ symbol, type, entryPrice, stopLoss, takeProfit, size, botId, strategy: stratName }) => {
    const cur = prices[symbol] ?? SYMBOLS_CFG[symbol].simBase;
    const { pnl, pnlPercent } = calcPnl(type, entryPrice, cur, size);
    setActiveTrades(prev => [...prev, {
      id: `live_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
      symbol, type, entryPrice, currentPrice: cur,
      stopLoss, takeProfit, pnl, pnlPercent,
      openedAt: Date.now(), size,
      botId:    botId ?? null,       // null = manual trade
      strategy: stratName ?? null,
    }]);
  }, [prices]);

  const closeTrade = useCallback(id => {
    setActiveTrades(prev => {
      const t = prev.find(x => x.id === id);
      if (t) setTimeout(() => addToJournal({ ...t, exitPrice: t.currentPrice }), 0);
      return prev.filter(x => x.id !== id);
    });
  }, [addToJournal]);

  // ── Journal trades — per account ─────────────────────────────
  const [journalTrades, setJournalTrades] = useState([]);

  // Load this account's trades on mount — FRESH START for new accounts (no demo trades)
  useEffect(() => {
    const saved = loadUserTrades(session.username);
    if (saved) {
      setJournalTrades(saved);   // could be [] for brand new account — that's correct
    } else {
      setJournalTrades([]);      // first ever login — start completely empty
      saveUserTrades(session.username, []); // mark as initialised so we don't re-init
    }
  }, [session.username]); // eslint-disable-line react-hooks/exhaustive-deps

  // Persist journal trades whenever they change
  useEffect(() => {
    saveUserTrades(session.username, journalTrades);
  }, [journalTrades, session.username]);

  // ── Active trades persistence ─────────────────────────────────
  // Save/restore open positions so they survive sign-out and page refresh
  const activeTradesKey = `tradedesk_active_${session.username}_v1`;

  const [activeTrades, setActiveTrades] = useState(() => {
    // Load on first render — sync so we don't flash empty state
    try {
      const saved = JSON.parse(localStorage.getItem(activeTradesKey) || "[]");
      return Array.isArray(saved) ? saved : [];
    } catch { return []; }
  });

  // Persist active trades on every change
  useEffect(() => {
    try { localStorage.setItem(activeTradesKey, JSON.stringify(activeTrades)); }
    catch {}
  }, [activeTrades, activeTradesKey]);

  // ── Active tab ────────────────────────────────────────────────
  const [tab, setTab]             = useState("chart");
  const [desktopTab, setDeskTab]  = useState("dashboard");
  const [orderOpen, setOrderOpen] = useState(false);
  const isMobile = useIsMobile();

  // ── Bots ──────────────────────────────────────────────────────
  const { bots, createBot, updateBot, deleteBot, toggleBot } = useBots(session.username);

  // Load all strategies so the engine can look them up by id
  const [allStrategies, setAllStrategies] = useState([]);
  useEffect(() => { setAllStrategies(loadAllStrategies()); }, [bots]);

  // ── Semi-auto pending signal toast ────────────────────────────
  const [pendingSignal, setPendingSignal] = useState(null);
  const [toastTimer,    setToastTimer]    = useState(30);

  // Timer countdown for pending signal
  useEffect(() => {
    if (!pendingSignal) return;
    setToastTimer(30);
    const interval = setInterval(() => {
      setToastTimer(t => {
        if (t <= 1) {
          // Time expired — skip the trade
          updateBot(pendingSignal.botId, { pendingSignal: null });
          setPendingSignal(null);
          clearInterval(interval);
          return 30;
        }
        return t - 1;
      });
    }, 1000);
    return () => clearInterval(interval);
  }, [pendingSignal?.timestamp]); // eslint-disable-line react-hooks/exhaustive-deps

  const handleApproveSignal = useCallback(() => {
    if (!pendingSignal) return;
    const bot    = bots.find(b => b.id === pendingSignal.botId);
    const symCfg = SYMBOLS_CFG[pendingSignal.symbol] ?? SYMBOLS_CFG.BTCUSD;
    if (bot) {
      openTrade({
        symbol:     pendingSignal.symbol,
        type:       pendingSignal.direction,
        entryPrice: pendingSignal.entry,
        stopLoss:   pendingSignal.sl,
        takeProfit: pendingSignal.tp,
        size:       1,
        botId:      bot.id,
        strategy:   bot.strategyName,
      });
      const log = `${new Date().toLocaleTimeString()} — User approved ${pendingSignal.direction} @ ${pendingSignal.entry.toFixed(symCfg.dec)}`;
      updateBot(bot.id, {
        pendingSignal:  null,
        tradesExecuted: (bot.tradesExecuted ?? 0) + 1,
        todayTrades:    (bot.todayTrades ?? 0) + 1,
        log:            [log, ...(bot.log ?? [])].slice(0, 20),
      });
    }
    setPendingSignal(null);
  }, [pendingSignal, bots, openTrade, updateBot]);


// ── Parse a Coinbase candle into our format ───────────────────
// Coinbase v3 returns objects: { start, low, high, open, close, volume }
function parseCoinbaseCandle(c, dec) {
  return {
    time:  parseInt(c.start),
    open:  +parseFloat(c.open).toFixed(dec),
    high:  +parseFloat(c.high).toFixed(dec),
    low:   +parseFloat(c.low).toFixed(dec),
    close: +parseFloat(c.close).toFixed(dec),
  };
}

// ── Fetch historical candles from Coinbase ────────────────────
// For daily timeframes, paginates up to 3 pages (900 bars ≈ 2.5 years)
// so long-term strategies have enough data to compute 200MA and fire signals.
async function fetchCoinbaseCandles(productId, granularity, count = 200) {
  const granSecs = {
    ONE_MINUTE: 60, FIVE_MINUTE: 300, FIFTEEN_MINUTE: 900,
    ONE_HOUR: 3600, SIX_HOUR: 21600, ONE_DAY: 86400,
  }[granularity] ?? 3600;

  const PER_PAGE = 300; // Coinbase hard limit per request
  // Paginate for: daily (need years), and short TFs (need many bars for stats)
  const shortTFs = ["ONE_MINUTE", "FIVE_MINUTE", "FIFTEEN_MINUTE"];
  const pages = (granularity === "ONE_DAY" || shortTFs.includes(granularity)) ? 3 : 1;
  const totalTarget = Math.min(count, pages * PER_PAGE);

  const now = Math.floor(Date.now() / 1000);
  const allCandles = [];

  for (let page = 0; page < pages; page++) {
    const pageEnd   = now - page * PER_PAGE * granSecs;
    const pageStart = pageEnd - PER_PAGE * granSecs;
    const params    = `product_id=${productId}&start=${pageStart}&end=${pageEnd}&granularity=${granularity}`;
    const url       = `/api/coinbase?params=${encodeURIComponent(params)}`;

    try {
      const res  = await fetch(url);
      if (!res.ok) break;
      const data = await res.json();
      if (!data.candles?.length) break;
      allCandles.push(...data.candles);
    } catch {
      break;
    }
  }

  if (!allCandles.length) throw new Error("No candles");

  // Sort by start time ascending (oldest first), deduplicate
  const seen = new Set();
  const unique = allCandles
    .filter(c => { const k = c.start; if (seen.has(k)) return false; seen.add(k); return true; })
    .sort((a, b) => parseInt(a.start) - parseInt(b.start));

  return unique;
}

// ── Simulated price engine (fallback for non-live symbols) ────
function nextTick(cur, cfg) {
  const drift = (cfg.simBase - cur) * 0.001;
  const noise = (Math.random() - 0.499) * cfg.simTick;
  return Math.max(cur + drift + noise, cfg.simBase * 0.5);
}

function genSimCandles(sym, tf = "1m", count = 200) {
  const cfg    = SYMBOLS_CFG[sym];
  const tfCfg  = TIMEFRAMES[tf] ?? TIMEFRAMES["1m"];
  const barSec = tfCfg.sec;
  const now    = Math.floor(Date.now() / barSec) * barSec;
  const out    = [];
  const vScale = Math.sqrt(barSec / 60);
  let p = cfg.simBase * (0.97 + Math.random() * 0.06);
  for (let i = count - 1; i >= 0; i--) {
    const time = now - i * barSec;
    const open = p;
    let hi = p, lo = p;
    const ticks = Math.max(4, tfCfg.ticksPerBar);
    for (let t = 0; t < ticks; t++) {
      p += (Math.random() - 0.5) * cfg.simTick * 0.7 * vScale;
      p = Math.max(p, cfg.simBase * 0.5);
      if (p > hi) hi = p;
      if (p < lo) lo = p;
    }
    out.push({ time, open: +open.toFixed(cfg.dec), high: +hi.toFixed(cfg.dec), low: +lo.toFixed(cfg.dec), close: +p.toFixed(cfg.dec) });
  }
  return out;
}

// Returns the start-of-bar timestamp (Unix sec) for the current timeframe
function currentBarSec(barSec) {
  return Math.floor(Date.now() / (barSec * 1000)) * barSec;
}

// Format candle time for x-axis label
function formatCandleTime(timeSec, tf) {
  const d   = new Date(timeSec * 1000);
  const pad = n => String(n).padStart(2, "0");
  if (["1m","5m","15m","1h","4h"].includes(tf))
    return `${pad(d.getHours())}:${pad(d.getMinutes())}`;
  if (["1D","1W"].includes(tf))
    return `${d.toLocaleString("en-US",{month:"short"})} ${d.getDate()}`;
  if (tf === "1M")
    return `${d.toLocaleString("en-US",{month:"short"})} '${String(d.getFullYear()).slice(2)}`;
  return String(d.getFullYear());
}




function StrategyBuilder({ session, initial, btCandles, btSource, btSymbol, btTf, loadBtCandles, onSave, onCancel }) {
  const [name,    setName]    = useState(initial?.name        ?? "");
  const [desc,    setDesc]    = useState(initial?.description ?? "");
  const [rules,   setRules]   = useState(initial?.rules       ?? []);
  const [isPublic,setPublic]  = useState(initial?.isPublic    ?? false);
  const [err,     setErr]     = useState("");
  const [preview, setPreview] = useState(null);
  const [previewSrc, setPreviewSrc] = useState(null);
  const [aiFlash, setAiFlash] = useState(false); // highlight rules section after AI fills it

  // Called when AI generator returns a result — populates the form
  const handleAIGenerated = (result) => {
    if (result.name)        setName(prev => prev || result.name);
    if (result.description) setDesc(prev => prev || result.description);
    if (result.rules?.length) {
      setRules(result.rules);
      setAiFlash(true);
      setTimeout(() => setAiFlash(false), 1500);
    }
    // If it's a daily strategy, auto-switch the backtest timeframe
    if (result.timeframe === "1D") {
      loadBtCandles(btSymbol, "1D");
    }
    setPreview(null); // reset old backtest
  };

  const runBacktest = () => {
    const candles = btCandles.length ? btCandles : genSimCandles("BTCUSD", "1h", 300);
    const result  = backtestStrategy(rules, candles);
    setPreview(result);
    setPreviewSrc(btCandles.length ? btSource : "sim");
  };

  const handleSave = (publish = false) => {
    if (!name.trim()) return setErr("Strategy name is required.");
    if (!rules.length) return setErr("Add at least one rule.");
    setErr("");

    const candles = btCandles.length ? btCandles : genSimCandles("BTCUSD", "1h", 300);
    const perf    = backtestStrategy(rules, candles);
    const strategy = {
      id:              initial?.id ?? `strat_${Date.now()}_${Math.random().toString(36).slice(2,6)}`,
      name:            name.trim(),
      description:     desc.trim(),
      rules,
      createdBy:       initial?.createdBy ?? session.username,
      createdAt:       initial?.createdAt ?? Date.now(),
      isPublic:        publish || isPublic,
      isSeed:          false,
      performance:     perf,
      backtestSource:  btCandles.length ? btSource : "sim",
    };
    onSave(strategy);
  };

  const inp = {
    width: "100%", padding: "10px 14px", borderRadius: 9,
    background: "#111827", border: "1px solid #1a2035",
    fontSize: 13, color: "#e2e8f0", outline: "none",
    boxSizing: "border-box", fontFamily: "inherit",
    transition: "border-color 0.15s",
  };
  const lbl = {
    display: "block", fontSize: 10, fontWeight: 700, color: "#475569",
    textTransform: "uppercase", letterSpacing: "0.07em", marginBottom: 7,
  };
  const sectionHead = { fontSize: 12, fontWeight: 700, color: "#94a3b8", marginBottom: 10, display: "flex", alignItems: "center", gap: 6 };

  return (
    <div style={{ maxWidth: 760, margin: "0 auto", display: "flex", flexDirection: "column", gap: 24 }}>

      {/* Header */}
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div>
          <div style={{ fontSize: 18, fontWeight: 800, color: "#f1f5f9" }}>
            {initial ? "Edit Strategy" : "New Strategy"}
          </div>
          <div style={{ fontSize: 11, color: "#475569", marginTop: 3 }}>
            Build your rules and backtest against simulated data
          </div>
        </div>
        <button onClick={onCancel} style={{ background: "none", border: "none", color: "#475569", cursor: "pointer", display: "flex", padding: 4 }}>
          <X size={18}/>
        </button>
      </div>

      {/* Name + Description */}
      <div style={{ background: "#0d1120", borderRadius: 12, border: "1px solid #1a2035", padding: "18px 20px", display: "flex", flexDirection: "column", gap: 14 }}>
        <div style={sectionHead}><Layers size={14}/> Strategy Info</div>
        <div>
          <label style={lbl}>Strategy Name</label>
          <input style={inp} placeholder="e.g. RSI Bounce Strategy" value={name} onChange={e => setName(e.target.value)}/>
        </div>
        <div>
          <label style={lbl}>Description</label>
          <textarea
            style={{ ...inp, resize: "vertical", minHeight: 72, fontFamily: "inherit", lineHeight: 1.5, fontSize: 12 }}
            placeholder="Describe what this strategy does, when it works best, and its key assumptions..."
            value={desc}
            onChange={e => setDesc(e.target.value)}
          />
        </div>
      </div>

      {/* AI Strategy Generator — above rules */}
      <AIStrategyGenerator
        onGenerated={handleAIGenerated}
        disabled={false}
      />

      {/* Rule builder */}
      <div style={{
        background: "#0d1120", borderRadius: 12,
        border: `1px solid ${aiFlash ? "rgba(99,102,241,0.5)" : "#1a2035"}`,
        padding: "18px 20px",
        transition: "border-color 0.4s",
        boxShadow: aiFlash ? "0 0 0 3px rgba(99,102,241,0.12)" : "none",
      }}>
        <div style={{ ...sectionHead, marginBottom: 14 }}>
          <Zap size={14}/> Rules
          {aiFlash && (
            <span style={{ fontSize: 9, fontWeight: 700, color: "#818cf8", background: "rgba(99,102,241,0.12)", border: "1px solid rgba(99,102,241,0.25)", padding: "2px 8px", borderRadius: 20, marginLeft: 6 }}>
              ✦ AI Generated
            </span>
          )}
        </div>
        <RuleBuilder rules={rules} onChange={setRules}/>
      </div>

      <div style={{ background: "#0d1120", borderRadius: 12, border: "1px solid #1a2035", padding: "18px 20px" }}>
        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 14 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
            <div style={sectionHead}><FlaskConical size={14}/> Backtest</div>
            {/* Data source badge */}
            {btSource === "loading" ? (
              <span style={{ fontSize: 9, color: "#64748b", display: "flex", alignItems: "center", gap: 4 }}>
                <span style={{ display: "inline-block", width: 7, height: 7, border: "1.5px solid #334155", borderTopColor: "#38bdf8", borderRadius: "50%", animation: "spin 0.7s linear infinite" }}/>
                Loading market data…
              </span>
            ) : btSource === "real" ? (
              <span style={{ fontSize: 9, fontWeight: 700, color: "#34d399", background: "rgba(16,185,129,0.08)", border: "1px solid rgba(16,185,129,0.2)", padding: "2px 8px", borderRadius: 20 }}>
                ● Real Binance {btSymbol} {btTf} · {btCandles.length} bars
              </span>
            ) : (
              <span style={{ fontSize: 9, fontWeight: 700, color: "#f59e0b", background: "rgba(245,158,11,0.08)", border: "1px solid rgba(245,158,11,0.2)", padding: "2px 8px", borderRadius: 20 }}>
                ⚠ Simulated data (Binance blocked)
              </span>
            )}
          </div>
          <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
            {/* Symbol + TF selectors */}
            <select
              defaultValue="BTCUSD"
              onChange={e => loadBtCandles(e.target.value, btTf)}
              style={{ padding: "4px 8px", borderRadius: 6, background: "#111827", border: "1px solid #1a2035", fontSize: 10, color: "#94a3b8", cursor: "pointer", outline: "none" }}
            >
              {SYM_LIST.map(s => <option key={s} value={s}>{s}</option>)}
            </select>
            <select
              defaultValue="1h"
              onChange={e => loadBtCandles(btSymbol, e.target.value)}
              style={{ padding: "4px 8px", borderRadius: 6, background: "#111827", border: "1px solid #1a2035", fontSize: 10, color: "#94a3b8", cursor: "pointer", outline: "none" }}
            >
              <optgroup label="── Scalping ──" style={{ color: "#fbbf24" }}>
                <option value="1m">1m  — 900 bars (~15 hrs)</option>
                <option value="5m">5m  — 900 bars (~3 days)</option>
                <option value="15m">15m — 900 bars (~9 days)</option>
              </optgroup>
              <optgroup label="── Swing ──" style={{ color: "#38bdf8" }}>
                <option value="1h">1h  — 300 bars (~13 days)</option>
                <option value="4h">4h  — 300 bars (~50 days)</option>
              </optgroup>
              <optgroup label="── Long-term ──" style={{ color: "#34d399" }}>
                <option value="1D">1D  — 900 bars (~2.5 years)</option>
              </optgroup>
            </select>
            <button onClick={runBacktest} style={{
              display: "flex", alignItems: "center", gap: 5, padding: "6px 14px", borderRadius: 8,
              border: "1px solid rgba(56,189,248,0.3)", background: "rgba(56,189,248,0.08)",
              color: "#38bdf8", fontSize: 11, fontWeight: 700, cursor: "pointer",
            }}>
              Run
            </button>
          </div>
        </div>

        {!preview ? (
          <div style={{ color: "#334155", fontSize: 12, textAlign: "center", padding: "16px 0" }}>
            Click "Run" to backtest against {btSource === "real" ? `real Binance ${btSymbol} ${btTf}` : "simulated"} data
          </div>
        ) : preview.totalTrades === 0 ? (
          <div style={{ color: "#64748b", fontSize: 12, padding: "12px", borderRadius: 8, background: "#111827" }}>
            No trades generated. Try loosening your conditions or adding more rules.
          </div>
        ) : (
          <div>
            <div style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: 10, marginBottom: 10 }}>
              {[
                { label: "Trades",   val: String(preview.totalTrades),                                          color: "#94a3b8" },
                { label: "Win Rate", val: `${preview.winRate}%`,                                                color: preview.winRate >= 50 ? "#34d399" : "#f87171" },
                { label: "PnL",      val: `${preview.pnl>=0?"+":""}${preview.pnl?.toFixed(0)}`,                color: preview.pnl >= 0 ? "#34d399" : "#f87171" },
                { label: "PnL %",    val: `${preview.pnlPercent>=0?"+":""}${preview.pnlPercent?.toFixed(2)}%`, color: preview.pnlPercent >= 0 ? "#34d399" : "#f87171" },
              ].map(({ label, val, color }) => (
                <div key={label} style={{ background: "#111827", borderRadius: 8, padding: "10px 12px", textAlign: "center" }}>
                  <div style={{ fontSize: 9, color: "#334155", textTransform: "uppercase", letterSpacing: "0.07em", marginBottom: 4 }}>{label}</div>
                  <div style={{ fontSize: 16, fontWeight: 700, fontFamily: "monospace", color }}>{val}</div>
                </div>
              ))}
            </div>
            <div style={{ fontSize: 9, color: "#78716c", fontStyle: "italic", display: "flex", alignItems: "center", gap: 4 }}>
              <FlaskConical size={9}/>
              {previewSrc === "real"
                ? `Backtested on ${btCandles.length} real Binance ${btSymbol} ${btTf} bars — past performance ≠ future results`
                : "Backtested on simulated data (Binance unavailable) — not meaningful for real trading"}
            </div>
            {["1m","5m","15m"].includes(btTf) && preview && preview.totalTrades > 0 && (
              <div style={{ marginTop: 8, padding: "8px 10px", borderRadius: 7, background: "rgba(251,191,36,0.06)", border: "1px solid rgba(251,191,36,0.15)", fontSize: 9, color: "#92400e", lineHeight: 1.6 }}>
                ⚡ <strong style={{ color: "#fbbf24" }}>Scalping note:</strong> Short-TF backtests look better than live trading because they ignore bid-ask spread (~0.03%), execution delay, and partial fills. Real scalping results will be worse. Need 50+ trades for significance — you have {preview.totalTrades}.
              </div>
            )}
          </div>
        )}
      </div>

      {/* Error */}
      {err && (
        <div style={{ display: "flex", alignItems: "center", gap: 8, padding: "10px 14px", borderRadius: 8, background: "rgba(239,68,68,0.08)", border: "1px solid rgba(239,68,68,0.2)", fontSize: 12, color: "#f87171" }}>
          <AlertCircle size={13}/>{err}
        </div>
      )}

      {/* Visibility + Actions */}
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", flexWrap: "wrap", gap: 10 }}>
        <label style={{ display: "flex", alignItems: "center", gap: 8, cursor: "pointer" }}>
          <div
            onClick={() => setPublic(v => !v)}
            style={{
              width: 36, height: 20, borderRadius: 10,
              background: isPublic ? "#38bdf8" : "#1a2035",
              position: "relative", transition: "background 0.2s", cursor: "pointer",
            }}
          >
            <div style={{
              width: 14, height: 14, borderRadius: "50%", background: "#fff",
              position: "absolute", top: 3, left: isPublic ? 18 : 3,
              transition: "left 0.2s",
            }}/>
          </div>
          <span style={{ fontSize: 12, color: "#64748b" }}>
            {isPublic ? <><Globe size={11} style={{ display: "inline", marginRight: 4 }}/>Visible in marketplace</> : "Private — only you can see this"}
          </span>
        </label>

        <div style={{ display: "flex", gap: 8 }}>
          <button onClick={onCancel} style={{ padding: "9px 18px", borderRadius: 9, border: "1px solid #1a2035", background: "transparent", color: "#64748b", fontSize: 12, fontWeight: 600, cursor: "pointer" }}>
            Cancel
          </button>
          <button onClick={() => handleSave(false)} style={{ padding: "9px 20px", borderRadius: 9, border: "1px solid #263d55", background: "#111827", color: "#94a3b8", fontSize: 12, fontWeight: 700, cursor: "pointer" }}>
            Save Draft
          </button>
          <button onClick={() => handleSave(true)} style={{ padding: "9px 20px", borderRadius: 9, border: "none", background: "linear-gradient(135deg,#0369a1,#38bdf8)", color: "#fff", fontSize: 12, fontWeight: 700, cursor: "pointer", boxShadow: "0 4px 16px rgba(56,189,248,0.2)" }}>
            {isPublic ? "Save & Publish" : "Save Strategy"}
          </button>
        </div>
      </div>
    </div>
  );
}


    <div style={{
      position: "fixed", bottom: 80, right: 20, zIndex: 200,
      width: 300, borderRadius: 14,
      background: "#0d1120",
      border: `1px solid ${isLong ? "rgba(52,211,153,0.4)" : "rgba(239,68,68,0.4)"}`,
      boxShadow: `0 8px 40px ${isLong ? "rgba(52,211,153,0.15)" : "rgba(239,68,68,0.15)"}`,

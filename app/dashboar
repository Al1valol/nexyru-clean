  );
}

// ═══════════════════════════════════════════════════════════════
//  PNL CHART TOOLTIP
// ═══════════════════════════════════════════════════════════════

function PnlTooltip({ active, payload, label }) {
  if (!active || !payload?.length) return null;
  const v   = payload[0].value;
  const pos = v >= 0;
  return (
    <div style={{
      borderRadius: 8, border: "1px solid #334155",
      background: "rgba(15,23,42,0.97)", padding: "8px 12px", fontSize: 12,
    }}>
      <div style={{ color: "#94a3b8", marginBottom: 3 }}>{label}</div>
      <div style={{ fontFamily: "monospace", fontWeight: 700, fontSize: 14, color: pos ? "#34d399" : "#f87171" }}>
        {pos ? "+" : ""}{v.toFixed(2)}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════
//  ANALYTICS ENGINE
// ═══════════════════════════════════════════════════════════════

function analyseGroup(trades) {
  if (!trades.length) return { count:0, wins:0, losses:0, winRate:0, totalPnl:0, avgPnl:0 };
  const wins   = trades.filter(t => t.pnl > 0);
  const losses = trades.filter(t => t.pnl < 0);
  const totalPnl = +trades.reduce((s, t) => s + t.pnl, 0).toFixed(2);
  return {
    count:    trades.length,
    wins:     wins.length,
    losses:   losses.length,
    winRate:  +((wins.length / trades.length) * 100).toFixed(1),
    totalPnl,
    avgPnl:   +(totalPnl / trades.length).toFixed(2),
  };
}

function getTradesByStrategy(trades) {
  const map = {};
  trades.forEach(t => {
    const key = t.strategy || "Untagged";
    if (!map[key]) map[key] = [];
    map[key].push(t);
  });
  return Object.entries(map)
    .map(([strategy, ts]) => ({ strategy, ...analyseGroup(ts) }))
    .sort((a, b) => b.totalPnl - a.totalPnl);
}

function getTradesByTag(trades) {
  const map = {};
  trades.forEach(t => {
    (t.tags ?? []).forEach(tag => {
      if (!map[tag]) map[tag] = [];
      map[tag].push(t);
    });
  });
  return Object.entries(map)
    .map(([tag, ts]) => ({ tag, ...analyseGroup(ts) }))
    .sort((a, b) => b.totalPnl - a.totalPnl);
}

function getConfidenceAnalysis(trades) {
  const byConf = {};
  trades.forEach(t => {
    const c = t.confidence ?? 3;
    if (!byConf[c]) byConf[c] = [];
    byConf[c].push(t);
  });
  const rows = [1,2,3,4,5].map(c => ({
    confidence: c,
    ...analyseGroup(byConf[c] ?? []),
  }));
  const tradesWithConf = trades.filter(t => t.confidence != null);
  const avgConf = tradesWithConf.length
    ? +(tradesWithConf.reduce((s, t) => s + t.confidence, 0) / tradesWithConf.length).toFixed(1)
    : 0;
  const high = analyseGroup(trades.filter(t => (t.confidence ?? 0) >= 4));
  const low  = analyseGroup(trades.filter(t => (t.confidence ?? 6) <= 2));
  return { rows, avgConf, high, low };
}

